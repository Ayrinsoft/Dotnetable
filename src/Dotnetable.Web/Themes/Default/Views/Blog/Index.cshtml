@model IReadOnlyList<Dotnetable.Web.Controllers.BlogController.PostView>
@{
    ViewData["Title"] = "Blog";
    Layout = "/Themes/Default/Views/Shared/_Layout.cshtml";
}

@await Html.PartialAsync("_PageHeader", ("Blog", "Blog"))

<section class="site-section">
    <div class="container">
        <div class="row g-4">
            @foreach (var post in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <article class="blog-card">
                        <div class="thumb" style="background-image:linear-gradient(135deg,#1d2433,#2a3346);"></div>
                        <div class="body">
                            <span class="tag">@post.Category</span>
                            <h3><a class="text-reset" asp-controller="Blog" asp-action="Post" asp-route-slug="@post.Slug">@post.Title</a></h3>
                            <p class="text-muted">@post.Excerpt</p>
                            <div class="meta d-flex justify-content-between">
                                <span><i class="bi bi-calendar3 me-1"></i>@post.Date.ToString("MMM d, yyyy")</span>
                                <span><i class="bi bi-person me-1"></i>@post.Author</span>
                            </div>
                        </div>
                    </article>
                </div>
            }
        </div>
    </div>
</section>
