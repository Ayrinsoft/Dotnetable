@{
    ViewData["Title"] = "Home";
    Layout = "/Themes/Default/Views/Shared/_Layout.cshtml";
}

<!-- ── Hero ───────────────────────────────────────────────────── -->
<section class="site-hero">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-7">
                <span class="badge-pill">Trusted by teams worldwide</span>
                <h1>Modern solutions to grow your business online</h1>
                <p class="lead">We design and build fast, reliable digital products that help your brand stand out and reach more customers every day.</p>
                <div class="d-flex flex-wrap gap-3 mt-4">
                    <button class="btn btn-primary btn-lg" onclick="openAuth('register')">Get started</button>
                    <a class="btn btn-outline-light btn-lg" asp-controller="Home" asp-action="Services">Our services</a>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ── Stats ──────────────────────────────────────────────────── -->
<section class="site-section py-5">
    <div class="container">
        <div class="row text-center g-4">
            <div class="col-6 col-lg-3 site-stat"><div class="num">12K+</div><div class="label">Happy clients</div></div>
            <div class="col-6 col-lg-3 site-stat"><div class="num">450+</div><div class="label">Projects delivered</div></div>
            <div class="col-6 col-lg-3 site-stat"><div class="num">99.9%</div><div class="label">Uptime</div></div>
            <div class="col-6 col-lg-3 site-stat"><div class="num">24/7</div><div class="label">Support</div></div>
        </div>
    </div>
</section>

<!-- ── Features ───────────────────────────────────────────────── -->
<section class="site-section bg-light">
    <div class="container">
        <div class="text-center mb-5">
            <span class="site-eyebrow">What we offer</span>
            <h2 class="site-section-title">Everything you need to succeed</h2>
            <p class="site-section-sub">A complete toolkit to launch, manage, and scale your presence online.</p>
        </div>
        <div class="row g-4">
            @{
                var features = new[]
                {
                    ("bi-rocket-takeoff", "Fast performance", "Optimized for speed so your visitors never wait."),
                    ("bi-shield-check", "Secure by design", "Built-in protection keeps your data and users safe."),
                    ("bi-phone", "Fully responsive", "Looks great on every screen, from phone to desktop."),
                    ("bi-graph-up-arrow", "Built to scale", "Grows with you, from your first user to your millionth."),
                    ("bi-palette", "Beautiful design", "Clean, modern interfaces that delight your customers."),
                    ("bi-headset", "Dedicated support", "A real team ready to help whenever you need us."),
                };
            }
            @foreach (var (icon, title, text) in features)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="site-card">
                        <div class="icon"><i class="bi @icon"></i></div>
                        <h3 class="h5 fw-bold">@title</h3>
                        <p class="text-muted mb-0">@text</p>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<!-- ── About strip ────────────────────────────────────────────── -->
<section class="site-section">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-6">
                <span class="site-eyebrow">Who we are</span>
                <h2 class="site-section-title">A partner you can rely on</h2>
                <p class="text-muted">We combine strategy, design, and engineering to deliver products that move your business forward. Our approach is collaborative, transparent, and focused on results.</p>
                <ul class="list-unstyled d-grid gap-2">
                    <li><i class="bi bi-check-circle-fill text-primary me-2"></i>Experienced, dedicated team</li>
                    <li><i class="bi bi-check-circle-fill text-primary me-2"></i>Transparent process and pricing</li>
                    <li><i class="bi bi-check-circle-fill text-primary me-2"></i>Long-term support and maintenance</li>
                </ul>
                <a class="btn btn-primary mt-3" asp-controller="Home" asp-action="About">Learn more</a>
            </div>
            <div class="col-lg-6">
                <div class="ratio ratio-4x3 rounded-4 bg-dark-section d-flex align-items-center justify-content-center text-center">
                    <div class="d-flex align-items-center justify-content-center">
                        <i class="bi bi-people display-1 text-primary"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ── Latest from blog ───────────────────────────────────────── -->
<section class="site-section bg-light">
    <div class="container">
        <div class="d-flex justify-content-between align-items-end mb-5 flex-wrap gap-2">
            <div>
                <span class="site-eyebrow">From the blog</span>
                <h2 class="site-section-title mb-0">Latest articles</h2>
            </div>
            <a class="btn btn-outline-secondary" asp-controller="Blog" asp-action="Index">View all posts</a>
        </div>
        <div class="row g-4">
            @foreach (var post in Dotnetable.Web.Controllers.BlogController.SamplePosts.Take(3))
            {
                <div class="col-md-6 col-lg-4">
                    <article class="blog-card">
                        <div class="thumb" style="background-image:linear-gradient(135deg,#1d2433,#2a3346);"></div>
                        <div class="body">
                            <span class="tag">@post.Category</span>
                            <h3><a class="text-reset" asp-controller="Blog" asp-action="Post" asp-route-slug="@post.Slug">@post.Title</a></h3>
                            <p class="text-muted">@post.Excerpt</p>
                            <div class="meta"><i class="bi bi-calendar3 me-1"></i>@post.Date.ToString("MMM d, yyyy")</div>
                        </div>
                    </article>
                </div>
            }
        </div>
    </div>
</section>

<!-- ── CTA ────────────────────────────────────────────────────── -->
<section class="site-section">
    <div class="container">
        <div class="site-cta text-center">
            <h2 class="fw-bold mb-2">Ready to get started?</h2>
            <p class="mb-4 opacity-75">Create your free account today and see what we can build together.</p>
            <button class="btn btn-light btn-lg fw-bold text-primary" onclick="openAuth('register')">Create your account</button>
        </div>
    </div>
</section>
