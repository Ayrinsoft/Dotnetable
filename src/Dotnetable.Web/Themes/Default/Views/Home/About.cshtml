@{
    ViewData["Title"] = "About";
    Layout = "/Themes/Default/Views/Shared/_Layout.cshtml";
}

@await Html.PartialAsync("_PageHeader", ("About us", "About"))

<section class="site-section">
    <div class="container">
        <div class="row g-5 align-items-center">
            <div class="col-lg-6">
                <span class="site-eyebrow">Our story</span>
                <h2 class="site-section-title">We help brands thrive in a digital world</h2>
                <p class="text-muted">From our first project to today, our mission has stayed the same: to build digital products that are fast, reliable, and a pleasure to use. We work closely with every client to understand their goals and turn them into reality.</p>
                <p class="text-muted">Our team blends design, engineering, and strategy under one roof, so your project moves smoothly from idea to launch and beyond.</p>
            </div>
            <div class="col-lg-6">
                <div class="ratio ratio-4x3 rounded-4 bg-dark-section d-flex align-items-center justify-content-center">
                    <div class="d-flex align-items-center justify-content-center">
                        <i class="bi bi-buildings display-1 text-primary"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="site-section bg-light">
    <div class="container">
        <div class="text-center mb-5">
            <span class="site-eyebrow">What drives us</span>
            <h2 class="site-section-title">Our values</h2>
        </div>
        <div class="row g-4">
            @{
                var values = new[]
                {
                    ("bi-lightbulb", "Innovation", "We embrace new ideas and technologies to deliver the best results."),
                    ("bi-hand-thumbs-up", "Quality", "We never cut corners — every detail matters."),
                    ("bi-people", "Collaboration", "We work as an extension of your team, openly and honestly."),
                };
            }
            @foreach (var (icon, title, text) in values)
            {
                <div class="col-md-4">
                    <div class="site-card text-center">
                        <div class="icon mx-auto"><i class="bi @icon"></i></div>
                        <h3 class="h5 fw-bold">@title</h3>
                        <p class="text-muted mb-0">@text</p>
                    </div>
                </div>
            }
        </div>
    </div>
</section>
