@page "/products"
@attribute [Authorize(Policy = AdminPolicies.WebsiteAdminOrAbove)]
@inject IProductService ProductService
@inject AuthenticationStateProvider AuthState

<PageTitle>Products</PageTitle>
<h1>Products</h1>

@if (_loading)
{
    <p>Loading...</p>
}
else
{
    <table>
        <thead>
            <tr><th>ID</th><th>Name</th><th>Price</th><th>Stock</th><th>Active</th></tr>
        </thead>
        <tbody>
            @foreach (var p in _products)
            {
                <tr>
                    <td>@p.Id</td>
                    <td>@p.Name</td>
                    <td>@p.Price.ToString("N2")</td>
                    <td>@p.Stock</td>
                    <td>@(p.IsActive ? "Yes" : "No")</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private bool _loading = true;
    private IEnumerable<Product> _products = [];

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthState.GetAuthenticationStateAsync();
        var websiteIdClaim = state.User.FindFirst(AdminClaimTypes.WebsiteId)?.Value;
        if (int.TryParse(websiteIdClaim, out var websiteId))
            _products = await ProductService.GetByWebsiteAsync(websiteId);
        _loading = false;
    }
}
