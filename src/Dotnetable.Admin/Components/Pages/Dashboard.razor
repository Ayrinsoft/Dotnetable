@page "/"
@attribute [Authorize]
@inject AuthenticationStateProvider AuthState

<PageTitle>Dashboard</PageTitle>
<h1>Dashboard</h1>

<AuthorizeView>
    <Authorized Context="authCtx">
        <p>Welcome, <strong>@authCtx.User.Identity?.Name</strong></p>

        <AuthorizeView Policy="@AdminPolicies.SuperAdminOnly" Context="superCtx">
            <p>You are a <strong>master website</strong> administrator — all websites are visible.</p>
        </AuthorizeView>

        <p>Your website ID: <strong>@authCtx.User.FindFirst(AdminClaimTypes.WebsiteId)?.Value</strong></p>
    </Authorized>
</AuthorizeView>
