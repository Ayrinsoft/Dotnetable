@page "/settings"
@attribute [Authorize(Policy = AdminPolicies.SuperAdminOnly)]
@using Dotnetable.Application.DTOs
@inject IAppSettingsStore AppSettings
@inject IEmailService EmailService
@inject ISnackbar Snackbar
@inject IPageLocalizer L

<DNPageTitle Title=@L["settings", "Settings"] />

@* ── Page header ──────────────────────────────────────────────── *@
<MudStack Spacing="0" Class="mb-6">
    <MudText Typo="Typo.h5" Class="fw-bold">@L["settings", "Settings"]</MudText>
    <MudText Typo="Typo.body2" Color="Color.Secondary">@L["settings.subtitle", "System-wide configuration"]</MudText>
</MudStack>

<MudGrid Spacing="4">

    @* ── Bot protection ───────────────────────────────────────── *@
    <MudItem xs="12" md="6">
        <MudPaper Elevation="0" Class="border rounded-lg pa-6 h-100">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-1">
                <MudIcon Icon="@Icons.Material.Filled.Shield" Color="Color.Primary" />
                <MudText Typo="Typo.subtitle1" Class="fw-bold">@L["settings.bot_protection", "Bot Protection"]</MudText>
            </MudStack>
            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
                @L["settings.bot_hint", "Protects login and forgot-password forms. Cloudflare Turnstile is used when keys are set; otherwise a math captcha is shown automatically."]
            </MudText>

            <MudSelect T="CaptchaMode" @bind-Value="_security.CaptchaMode" Label="@L["settings.captcha_mode", "Captcha Mode"]"
                       Variant="Variant.Outlined" Class="mb-3">
                <MudSelectItem T="CaptchaMode" Value="CaptchaMode.Auto">
                    @L["settings.captcha_auto", "Auto — Turnstile if configured, else math"]
                </MudSelectItem>
                <MudSelectItem T="CaptchaMode" Value="CaptchaMode.Turnstile">
                    @L["settings.captcha_turnstile", "Turnstile — falls back to math if unreachable"]
                </MudSelectItem>
                <MudSelectItem T="CaptchaMode" Value="CaptchaMode.Math">
                    @L["settings.captcha_math", "Math captcha only"]
                </MudSelectItem>
            </MudSelect>

            <MudTextField @bind-Value="_security.TurnstileSiteKey" Label="@L["settings.turnstile_site", "Turnstile Site Key"]"
                          Variant="Variant.Outlined" Class="mb-3" Clearable="true"
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.VpnKey" />
            <MudTextField @bind-Value="_security.TurnstileSecretKey" Label="@L["settings.turnstile_secret", "Turnstile Secret Key"]"
                          Variant="Variant.Outlined" Class="mb-5" InputType="InputType.Password"
                          Clearable="true" />

            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Save"
                       OnClick="SaveSecurity" Disabled="@_savingSecurity">
                @if (_savingSecurity)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-2" />
                }
                @L["settings.save_protection", "Save Protection"]
            </MudButton>
        </MudPaper>
    </MudItem>

    @* ── Email / SMTP ─────────────────────────────────────────── *@
    <MudItem xs="12" md="6">
        <MudPaper Elevation="0" Class="border rounded-lg pa-6 h-100">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2" Class="mb-1">
                <MudIcon Icon="@Icons.Material.Filled.Email" Color="Color.Primary" />
                <MudText Typo="Typo.subtitle1" Class="fw-bold">@L["settings.email_smtp", "Email (SMTP)"]</MudText>
            </MudStack>
            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
                @L["settings.email_hint", "Used to send forgot-password links. Leave empty to disable outgoing email."]
            </MudText>

            <MudGrid Spacing="2" Class="mb-2">
                <MudItem xs="12" sm="8">
                    <MudTextField @bind-Value="_email.MailServer" Label="@L["email.smtp_server", "SMTP Server"]"
                                  Variant="Variant.Outlined"
                                  Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Dns" />
                </MudItem>
                <MudItem xs="12" sm="4">
                    <MudNumericField @bind-Value="_email.SmtpPort" Label="@L["port", "Port"]"
                                     Min="1" Max="65535" Variant="Variant.Outlined" />
                </MudItem>
            </MudGrid>

            <MudCheckBox T="bool" @bind-Value="_email.EnableSSL" Label="@L["email.enable_ssl", "Enable SSL / TLS"]" Color="Color.Primary" Class="mb-2" />

            <MudTextField @bind-Value="_email.EmailAddress" Label="@L["email.from_address", "From Address / Username"]"
                          Variant="Variant.Outlined" Class="mb-2" InputType="InputType.Email"
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.AlternateEmail" />
            <MudTextField @bind-Value="_email.Password" Label="@L["password", "Password"]"
                          Variant="Variant.Outlined" Class="mb-2" InputType="InputType.Password" />
            <MudTextField @bind-Value="_email.MailName" Label="@L["email.from_name", "From Display Name"]"
                          Variant="Variant.Outlined" Class="mb-5" />

            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Save"
                       OnClick="SaveEmail" Disabled="@_savingEmail">
                @if (_savingEmail)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-2" />
                }
                @L["settings.save_email", "Save Email"]
            </MudButton>
        </MudPaper>
    </MudItem>

</MudGrid>

@code {
    private SecuritySettings _security = new();
    private EmailSettingsInfo _email = new();
    private bool _savingSecurity;
    private bool _savingEmail;

    protected override async Task OnInitializedAsync()
    {
        await L.EnsureLoadedAsync();
        _security = AppSettings.Security;
        _email = await EmailService.GetDefaultAsync() ?? new EmailSettingsInfo();
    }

    private async Task SaveSecurity()
    {
        _savingSecurity = true;
        try
        {
            await AppSettings.SaveSecurityAsync(_security);
            Snackbar.Add(L["settings.bot_saved", "Bot protection settings saved."], Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"{L["save_failed", "Save failed"]}: {ex.Message}", Severity.Error);
        }
        finally { _savingSecurity = false; }
    }

    private async Task SaveEmail()
    {
        _savingEmail = true;
        try
        {
            await EmailService.SaveDefaultAsync(_email);
            Snackbar.Add(L["email.saved", "Email settings saved."], Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"{L["save_failed", "Save failed"]}: {ex.Message}", Severity.Error);
        }
        finally { _savingEmail = false; }
    }
}
