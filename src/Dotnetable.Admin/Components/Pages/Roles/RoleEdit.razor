@page "/roles/new"
@page "/roles/{Id:int}"
@attribute [Authorize(Policy = AdminPolicies.SuperAdminOnly)]
@inject IRoleService RoleService
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject IPageLocalizer L

<DNPageTitle Title=@(_isNew ? L["role.new", "New Role"] : L["role.edit", "Edit Role"]) />

<MudBreadcrumbs Items="_breadcrumbs" Class="px-0 pb-2" />

<MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
    <MudStack Spacing="0">
        <MudText Typo="Typo.h5" Class="fw-bold">@(_isNew ? L["role.new", "New Role"] : L["role.edit", "Edit Role"])</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">
            @(_isNew ? L["role.new_subtitle", "Define a new permission key"] : $"{L["role.editing", "Editing role"]} #{Id}")
        </MudText>
    </MudStack>
</MudStack>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4" />
}
else if (_role is not null)
{
    <MudForm @ref="_form">
        <MudPaper Elevation="0" Class="border rounded-lg pa-6">
            <MudGrid Spacing="3">
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_role.RoleKey" Label="@L["key", "Key"]"
                                  Variant="Variant.Outlined" Required="true" MaxLength="42"
                                  RequiredError="@L["required", "This field is required."]" Placeholder="manage.something" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudTextField @bind-Value="_role.Description" Label="@L["description", "Description"]"
                                  Variant="Variant.Outlined" Required="true" MaxLength="128"
                                  RequiredError="@L["required", "This field is required."]" />
                </MudItem>
                <MudItem xs="12" sm="6">
                    <MudSelect T="byte" @bind-Value="_role.Category" Label="@L["role.category", "Category"]"
                               Variant="Variant.Outlined">
                        <MudSelectItem T="byte" Value="@((byte)RoleCategory.Admin)">@L["role.category.admin", "Admin panel"]</MudSelectItem>
                        <MudSelectItem T="byte" Value="@((byte)RoleCategory.Client)">@L["role.category.client", "Website client"]</MudSelectItem>
                    </MudSelect>
                </MudItem>
                <MudItem xs="12">
                    <MudSwitch T="bool" @bind-Value="_role.Active" Color="Color.Primary"
                               Label="@(_role.Active ? L["active", "Active"] : L["inactive", "Inactive"])" />
                </MudItem>
            </MudGrid>
        </MudPaper>

        <MudStack Row="true" Class="mt-4" Spacing="2">
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Save"
                       OnClick="SaveAsync" Disabled="@_saving">
                @if (_saving)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-2" />
                }
                @(_isNew ? L["role.create", "Create Role"] : L["save", "Save Changes"])
            </MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Default"
                       StartIcon="@Icons.Material.Filled.ArrowBack" Href="/roles">
                @L["cancel", "Cancel"]
            </MudButton>
        </MudStack>
    </MudForm>
}

@code {
    [Parameter] public int Id { get; set; }

    private MudForm _form = null!;
    private Role? _role;
    private bool _loading = true;
    private bool _saving;
    private bool _isNew => Id == 0;

    private List<BreadcrumbItem> _breadcrumbs => new()
    {
        new(L["dashboard", "Dashboard"], "/"),
        new(L["roles", "Roles"], "/roles"),
        new(_isNew ? L["new", "New"] : $"#{Id}", null, true),
    };

    protected override async Task OnInitializedAsync()
    {
        await L.EnsureLoadedAsync();

        if (_isNew)
        {
            _role = new Role { Active = true };
        }
        else
        {
            _role = await RoleService.GetByIdAsync((short)Id);
            if (_role is null) Nav.NavigateTo("/roles");
        }
        _loading = false;
    }

    private async Task SaveAsync()
    {
        await _form.ValidateAsync();
        if (!_form.IsValid) return;

        _saving = true;
        try
        {
            if (_isNew)
            {
                await RoleService.CreateAsync(_role!);
                Snackbar.Add(L["role.created", "Role created successfully."], Severity.Success);
            }
            else
            {
                await RoleService.UpdateAsync(_role!);
                Snackbar.Add(L["saved", "Changes saved successfully."], Severity.Success);
            }
            Nav.NavigateTo("/roles");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"{L["save_failed", "Save failed"]}: {ex.Message}", Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }
}
