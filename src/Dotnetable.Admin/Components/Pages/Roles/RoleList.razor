@page "/roles"
@attribute [Authorize(Policy = AdminPolicies.SuperAdminOnly)]
@inject IRoleService RoleService
@inject ISnackbar Snackbar
@inject IPageLocalizer L

<DNPageTitle Title=@L["roles", "Roles"] />

<MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
    <MudStack Spacing="0">
        <MudText Typo="Typo.h5" Class="fw-bold">@L["roles", "Roles"]</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">@L["role.subtitle", "System-wide permission keys"]</MudText>
    </MudStack>
    <MudButton Variant="Variant.Filled" Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.Add" Href="/roles/new">
        @L["role.new", "New Role"]
    </MudButton>
</MudStack>

<MudPaper Elevation="0" Class="app-card rounded-lg pa-4">
    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-3" />
    }
    <DNGridView GridHeaderParams="_grid" OnSearchChanged="OnGridChanged">
        @if (_roles.Count == 0)
        {
            <tr>
                <td colspan="5" style="text-align:center; padding:32px;">
                    <MudText Color="Color.Secondary">@L["role.empty", "No roles found."]</MudText>
                </td>
            </tr>
        }
        else
        {
            @foreach (var r in _roles)
            {
                <tr>
                    <td>
                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                       Color="Color.Primary" Href="@($"/roles/{r.RoleID}")" />
                    </td>
                    <td>@r.RoleID</td>
                    <td><code>@r.RoleKey</code></td>
                    <td>@r.Description</td>
                    <td>
                        <MudSwitch T="bool" Value="r.Active" Color="Color.Success"
                                   Disabled="_toggling.Contains(r.RoleID)"
                                   ValueChanged="@(v => ToggleActiveAsync(r, v))" />
                    </td>
                </tr>
            }
        }
    </DNGridView>
</MudPaper>

@code {
    private bool _loading = true;
    private List<Role> _roles = new();
    private HashSet<short> _toggling = new();
    private GridViewHeaderParameters _grid = new();

    private async Task ToggleActiveAsync(Role r, bool value)
    {
        if (!_toggling.Add(r.RoleID)) return;
        r.Active = value;
        try { await RoleService.SetActiveAsync(r.RoleID, value); }
        finally { _toggling.Remove(r.RoleID); }
    }

    protected override async Task OnInitializedAsync()
    {
        await L.EnsureLoadedAsync();

        _grid = new GridViewHeaderParameters
        {
            Pagination = new PaginationModel { PageSize = 25 },
            HeaderItems = new()
            {
                new() { ColumnTitle = "", ColumnName = "" },
                new() { ColumnTitle = L["id", "ID"], ColumnName = nameof(Role.RoleID), HasSort = true },
                new() { ColumnTitle = L["key", "Key"], ColumnName = nameof(Role.RoleKey), HasSort = true, HasSearch = true },
                new() { ColumnTitle = L["description", "Description"], ColumnName = nameof(Role.Description), HasSearch = true },
                new()
                {
                    ColumnTitle = L["status", "Status"],
                    ColumnName = nameof(Role.Active),
                    HasSearch = true,
                    SearchType = SearchColumnType.DropDown,
                    OtherDropDownValues = new() { [L["active", "Active"]] = "true", [L["inactive", "Inactive"]] = "false" }
                },
            }
        };

        await LoadAsync();
    }

    private Task OnGridChanged(GridViewHeaderParameters _) => LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        var result = await RoleService.GetPagedAsync(_grid.ToQuery());
        _roles = result.Items.ToList();
        _grid.Pagination.MaxLength = result.TotalCount;
        _loading = false;
    }
}
