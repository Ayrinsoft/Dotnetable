@page "/users"
@attribute [Authorize(Policy = AdminPolicies.SuperAdminOnly)]
@inject IUserService UserService

<PageTitle>Users</PageTitle>
<h1>Users</h1>

@if (_loading)
{
    <p>Loading...</p>
}
else
{
    <table>
        <thead>
            <tr><th>ID</th><th>Username</th><th>Email</th><th>Role</th><th>Website</th><th>Active</th></tr>
        </thead>
        <tbody>
            @foreach (var u in _users)
            {
                <tr>
                    <td>@u.Id</td>
                    <td>@u.Username</td>
                    <td>@u.Email</td>
                    <td>@u.Role</td>
                    <td>@u.WebsiteId</td>
                    <td>@(u.IsActive ? "Yes" : "No")</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private bool _loading = true;
    private IEnumerable<User> _users = [];

    protected override async Task OnInitializedAsync()
    {
        _users = await UserService.GetAllAsync();
        _loading = false;
    }
}
