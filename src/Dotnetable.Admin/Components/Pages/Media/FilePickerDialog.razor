@inject IFileService FileService
@inject IDialogService DialogService

<MudDialog>
    <TitleContent>
        <MudText Typo="Typo.h6">
            <MudIcon Icon="@Icons.Material.Filled.PermMedia" Class="me-2" />
            Select a file
        </MudText>
    </TitleContent>
    <DialogContent>
        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center" Class="mb-3">
            <MudTextField @bind-Value="_search" Placeholder="Search…" Variant="Variant.Outlined"
                          Margin="Margin.Dense" Immediate="false" OnKeyUp="OnSearchKey"
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" />
            <MudSpacer />
            <MudButton StartIcon="@Icons.Material.Filled.CloudUpload" Color="Color.Primary"
                       Variant="Variant.Outlined" OnClick="OpenUploadAsync">Upload</MudButton>
        </MudStack>

        @if (_loading)
        {
            <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-3" />
        }

        @if (_items.Count == 0 && !_loading)
        {
            <MudText Color="Color.Secondary" Class="pa-4" Align="Align.Center">No files. Upload one to get started.</MudText>
        }
        else
        {
            <div style="display:grid; grid-template-columns:repeat(auto-fill,minmax(120px,1fr)); gap:10px; max-height:420px; overflow:auto;">
                @foreach (var f in _items)
                {
                    <MudPaper Elevation="0" Class="border rounded-lg" Style="overflow:hidden; cursor:pointer;"
                              @onclick="@(() => Select(f))">
                        <div style="aspect-ratio:1; display:flex; align-items:center; justify-content:center; background:var(--mud-palette-background-grey); overflow:hidden;">
                            @if (f.FileCategory == (byte)FileCategory.Image && !string.IsNullOrEmpty(f.CNDUrl))
                            {
                                <img src="@(f.ThumbnailCDN ?? f.CNDUrl)" alt="@f.AltText" loading="lazy"
                                     style="width:100%; height:100%; object-fit:cover;" />
                            }
                            else
                            {
                                <MudIcon Icon="@MediaFormat.CategoryIcon(f.FileCategory)" Color="Color.Secondary" />
                            }
                        </div>
                        <MudText Typo="Typo.caption" Class="d-block text-truncate pa-1" title="@f.OriginalFileName">
                            @(string.IsNullOrWhiteSpace(f.Title) ? f.OriginalFileName : f.Title)
                        </MudText>
                    </MudPaper>
                }
            </div>

            @if (_total > _pageSize)
            {
                <div class="d-flex justify-center mt-3">
                    <MudPagination Count="@((_total + _pageSize - 1) / _pageSize)" Selected="_pageIndex"
                                   SelectedChanged="OnPageChanged" Color="Color.Primary" />
                </div>
            }
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] private IMudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public int WebsiteId { get; set; }

    /// <summary>Restrict selectable files to one category (e.g. Image for logo pickers).</summary>
    [Parameter] public FileCategory? Category { get; set; }

    private bool _loading = true;
    private string? _search;
    private int _pageIndex = 1;
    private const int _pageSize = 18;
    private int _total;
    private List<FileRecord> _items = new();

    protected override Task OnInitializedAsync() => LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        var filter = new FileFilter { Category = Category, Search = _search };
        var result = await FileService.GetPagedAsync(WebsiteId, filter,
            new GridQuery { PageIndex = _pageIndex, PageSize = _pageSize });
        _items = result.Items.ToList();
        _total = result.TotalCount;
        _loading = false;
    }

    private async Task OnSearchKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") { _pageIndex = 1; await LoadAsync(); }
    }

    private async Task OnPageChanged(int page) { _pageIndex = page; await LoadAsync(); }

    private async Task OpenUploadAsync()
    {
        var parameters = new DialogParameters { [nameof(UploadDialog.WebsiteId)] = WebsiteId };
        var dialog = await DialogService.ShowAsync<UploadDialog>("Upload", parameters,
            new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true });
        if ((await dialog.Result) is { Canceled: false }) await LoadAsync();
    }

    private void Select(FileRecord file) => MudDialog.Close(DialogResult.Ok(file));
    private void Cancel() => MudDialog.Cancel();
}
