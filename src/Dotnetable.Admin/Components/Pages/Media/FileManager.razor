@page "/media"
@attribute [Authorize(Policy = AdminPolicies.WebsiteAdminOrAbove)]
@inject IFileService FileService
@inject IWebsiteService WebsiteService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthState
@inject IPageLocalizer L

<DNPageTitle Title=@L["media_library", "Media Library"] />

<MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
    <MudStack Spacing="0">
        <MudText Typo="Typo.h5" Class="fw-bold">@L["media_library", "Media Library"]</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">@L["media.subtitle", "Browse, organize and upload files"]</MudText>
    </MudStack>
    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
        @if (_isMaster)
        {
            <MudSelect T="int" Value="_websiteId" ValueChanged="OnWebsiteChanged" Label="@L["website", "Website"]"
                       Variant="Variant.Outlined" Dense="true" Style="min-width:180px;">
                @foreach (var w in _websites)
                {
                    <MudSelectItem T="int" Value="w.WebsiteID">@w.BrandName (@w.WebsiteID)</MudSelectItem>
                }
            </MudSelect>
        }
        <MudButton Variant="Variant.Outlined" Color="Color.Default"
                   StartIcon="@Icons.Material.Filled.Cloud" Href="/media/storage">@L["storage", "Storage"]</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.CloudUpload" OnClick="OpenUploadAsync">@L["media.upload", "Upload"]</MudButton>
    </MudStack>
</MudStack>

<MudGrid Spacing="3">
    @* ── Left rail ─────────────────────────────────────── *@
    <MudItem xs="12" md="3">
        <MudPaper Elevation="0" Class="app-card rounded-lg pa-3">
            <MudNavMenu>
                <MudNavLink Icon="@Icons.Material.Filled.PhotoLibrary"
                            OnClick="@(() => SelectAlbum(null))"
                            Class="@(_filter.AlbumID is null ? "mud-selected-item" : "")">@L["media.all_files", "All files"]</MudNavLink>
            </MudNavMenu>

            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mt-3 mb-1">
                <MudText Typo="Typo.caption" Class="fw-bold text-uppercase">@L["media.albums", "Albums"]</MudText>
            </MudStack>
            @foreach (var a in _albums)
            {
                <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween"
                          Class="@($"px-2 py-1 rounded {(_filter.AlbumID == a.FileAlbumID ? "mud-selected-item" : "")}")"
                          Style="cursor:pointer;">
                    <span @onclick="@(() => SelectAlbum(a.FileAlbumID))" style="flex:1;">@a.Name</span>
                    <MudIconButton Icon="@Icons.Material.Filled.Close" Size="Size.Small"
                                   OnClick="@(() => DeleteAlbumAsync(a))" />
                </MudStack>
            }
            <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center" Class="mt-1">
                <MudTextField @bind-Value="_newAlbum" Placeholder="@L["media.new_album", "New album"]" Variant="Variant.Text"
                              Margin="Margin.Dense" Immediate="true" />
                <MudIconButton Icon="@Icons.Material.Filled.Add" Color="Color.Primary" Size="Size.Small"
                               OnClick="AddAlbumAsync" />
            </MudStack>

            <MudDivider Class="my-3" />

            <MudText Typo="Typo.caption" Class="fw-bold text-uppercase">@L["media.category", "Category"]</MudText>
            <MudSelect T="FileCategory?" Value="_filter.Category" ValueChanged="OnCategoryChanged"
                       Clearable="true" Variant="Variant.Outlined" Margin="Margin.Dense" Class="mt-1">
                <MudSelectItem T="FileCategory?" Value="FileCategory.Image">@L["media.cat_images", "Images"]</MudSelectItem>
                <MudSelectItem T="FileCategory?" Value="FileCategory.Document">@L["media.cat_documents", "Documents"]</MudSelectItem>
                <MudSelectItem T="FileCategory?" Value="FileCategory.Video">@L["media.cat_video", "Video"]</MudSelectItem>
                <MudSelectItem T="FileCategory?" Value="FileCategory.Audio">@L["media.cat_audio", "Audio"]</MudSelectItem>
                <MudSelectItem T="FileCategory?" Value="FileCategory.Other">@L["media.cat_other", "Other"]</MudSelectItem>
            </MudSelect>

            <MudText Typo="Typo.caption" Class="fw-bold text-uppercase mt-3 d-block">@L["media.tags", "Tags"]</MudText>
            <div class="d-flex flex-wrap gap-1 mt-1">
                @foreach (var t in _tags)
                {
                    <MudChip T="string" Size="Size.Small"
                             Color="@(_filter.TagID == t.FileTagID ? Color.Primary : Color.Default)"
                             Variant="@(_filter.TagID == t.FileTagID ? Variant.Filled : Variant.Outlined)"
                             OnClick="@(() => ToggleTag(t.FileTagID))"
                             OnClose="@(() => DeleteTagAsync(t))">@t.Name</MudChip>
                }
            </div>
            <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center" Class="mt-1">
                <MudTextField @bind-Value="_newTag" Placeholder="@L["media.new_tag", "New tag"]" Variant="Variant.Text"
                              Margin="Margin.Dense" Immediate="true" />
                <MudIconButton Icon="@Icons.Material.Filled.Add" Color="Color.Primary" Size="Size.Small"
                               OnClick="AddTagAsync" />
            </MudStack>
        </MudPaper>
    </MudItem>

    @* ── Gallery ──────────────────────────────────────── *@
    <MudItem xs="12" md="9">
        <MudPaper Elevation="0" Class="app-card rounded-lg pa-4">
            <MudTextField @bind-Value="_search" Placeholder="@L["media.search", "Search files…"]" Variant="Variant.Outlined"
                          Margin="Margin.Dense" Immediate="false" Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search" OnKeyUp="OnSearchKey" Class="mb-3" />

            @if (_loading)
            {
                <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-3" />
            }

            @if (_items.Count == 0 && !_loading)
            {
                <div style="text-align:center; padding:48px;">
                    <MudIcon Icon="@Icons.Material.Filled.ImageNotSupported" Size="Size.Large" Color="Color.Secondary" />
                    <MudText Color="Color.Secondary" Class="mt-2">@L["media.empty", "No files found."]</MudText>
                </div>
            }
            else
            {
                <div class="app-media-grid" style="display:grid; grid-template-columns:repeat(auto-fill,minmax(140px,1fr)); gap:12px;">
                    @foreach (var f in _items)
                    {
                        <MudPaper Elevation="0" Class="border rounded-lg" Style="overflow:hidden; cursor:pointer;"
                                  @onclick="@(() => OpenDetailAsync(f.FileRecordID))">
                            <div style="aspect-ratio:1; display:flex; align-items:center; justify-content:center; background:var(--mud-palette-background-grey); overflow:hidden;">
                                @if (f.FileCategory == (byte)FileCategory.Image && !string.IsNullOrEmpty(f.CNDUrl))
                                {
                                    <img src="@(f.ThumbnailCDN ?? f.CNDUrl)" alt="@f.AltText"
                                         loading="lazy" style="width:100%; height:100%; object-fit:cover;" />
                                }
                                else
                                {
                                    <MudIcon Icon="@MediaFormat.CategoryIcon(f.FileCategory)" Size="Size.Large" Color="Color.Secondary" />
                                }
                            </div>
                            <div class="pa-2">
                                <MudText Typo="Typo.caption" Class="d-block text-truncate" title="@f.OriginalFileName">
                                    @(string.IsNullOrWhiteSpace(f.Title) ? f.OriginalFileName : f.Title)
                                </MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">@MediaFormat.Size(f.FileSizeKB)</MudText>
                            </div>
                        </MudPaper>
                    }
                </div>

                @if (_total > _pageSize)
                {
                    <div class="d-flex justify-center mt-4">
                        <MudPagination Count="@((_total + _pageSize - 1) / _pageSize)" Selected="_pageIndex"
                                       SelectedChanged="OnPageChanged" Color="Color.Primary" />
                    </div>
                }
            }
        </MudPaper>
    </MudItem>
</MudGrid>

@code {
    private bool _isMaster;
    private int _websiteId;
    private bool _loading = true;

    private List<Website> _websites = new();
    private List<FileRecord> _items = new();
    private IReadOnlyList<FileAlbum> _albums = Array.Empty<FileAlbum>();
    private IReadOnlyList<FileTag> _tags = Array.Empty<FileTag>();

    private readonly FileFilter _filter = new();
    private string? _search;
    private string? _newAlbum;
    private string? _newTag;
    private int _pageIndex = 1;
    private const int _pageSize = 24;
    private int _total;

    protected override async Task OnInitializedAsync()
    {
        await L.EnsureLoadedAsync();

        var user = (await AuthState.GetAuthenticationStateAsync()).User;
        _isMaster = user.HasClaim(AdminClaimTypes.Master, "true");
        int.TryParse(user.FindFirst(AdminClaimTypes.WebsiteId)?.Value, out _websiteId);

        if (_isMaster)
        {
            _websites = (await WebsiteService.GetAllAsync()).ToList();
            if (_websiteId == 0 && _websites.Count > 0) _websiteId = _websites[0].WebsiteID;
        }
        await ReloadSidebarAsync();
        await LoadAsync();
    }

    private async Task OnWebsiteChanged(int websiteId)
    {
        _websiteId = websiteId;
        _filter.AlbumID = null;
        _filter.TagID = null;
        await ReloadSidebarAsync();
        await LoadAsync();
    }

    private async Task ReloadSidebarAsync()
    {
        _albums = await FileService.GetAlbumsAsync(_websiteId);
        _tags = await FileService.GetTagsAsync(_websiteId);
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _filter.Search = _search;
        var result = await FileService.GetPagedAsync(_websiteId, _filter,
            new GridQuery { PageIndex = _pageIndex, PageSize = _pageSize });
        _items = result.Items.ToList();
        _total = result.TotalCount;
        _loading = false;
    }

    private async Task SelectAlbum(int? albumId) { _filter.AlbumID = albumId; _pageIndex = 1; await LoadAsync(); }
    private async Task ToggleTag(int tagId) { _filter.TagID = _filter.TagID == tagId ? null : tagId; _pageIndex = 1; await LoadAsync(); }
    private async Task OnCategoryChanged(FileCategory? c) { _filter.Category = c; _pageIndex = 1; await LoadAsync(); }
    private async Task OnPageChanged(int page) { _pageIndex = page; await LoadAsync(); }

    private async Task OnSearchKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") { _pageIndex = 1; await LoadAsync(); }
    }

    private async Task AddAlbumAsync()
    {
        if (string.IsNullOrWhiteSpace(_newAlbum)) return;
        await FileService.CreateAlbumAsync(_websiteId, _newAlbum.Trim(), null);
        _newAlbum = null;
        await ReloadSidebarAsync();
    }

    private async Task DeleteAlbumAsync(FileAlbum album)
    {
        var ok = await DialogService.ShowMessageBoxAsync(L["media.delete_album_q", "Delete album?"],
            $"\"{album.Name}\" {L["media.delete_album_body", "will be removed. Files inside stay in the library."]}", yesText: L["delete", "Delete"], cancelText: L["cancel", "Cancel"]);
        if (ok == true)
        {
            await FileService.DeleteAlbumAsync(album.FileAlbumID);
            if (_filter.AlbumID == album.FileAlbumID) _filter.AlbumID = null;
            await ReloadSidebarAsync();
            await LoadAsync();
        }
    }

    private async Task AddTagAsync()
    {
        if (string.IsNullOrWhiteSpace(_newTag)) return;
        await FileService.CreateTagAsync(_websiteId, _newTag.Trim());
        _newTag = null;
        await ReloadSidebarAsync();
    }

    private async Task DeleteTagAsync(FileTag tag)
    {
        await FileService.DeleteTagAsync(tag.FileTagID);
        if (_filter.TagID == tag.FileTagID) _filter.TagID = null;
        await ReloadSidebarAsync();
        await LoadAsync();
    }

    private async Task OpenUploadAsync()
    {
        var parameters = new DialogParameters
        {
            [nameof(UploadDialog.WebsiteId)] = _websiteId,
            [nameof(UploadDialog.PresetAlbumId)] = _filter.AlbumID,
        };
        var dialog = await DialogService.ShowAsync<UploadDialog>(L["media.upload", "Upload"], parameters,
            new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true });
        if ((await dialog.Result) is { Canceled: false }) await LoadAsync();
    }

    private async Task OpenDetailAsync(int fileId)
    {
        var parameters = new DialogParameters
        {
            [nameof(FileDetailDialog.FileId)] = fileId,
            [nameof(FileDetailDialog.WebsiteId)] = _websiteId,
        };
        var dialog = await DialogService.ShowAsync<FileDetailDialog>(L["media.file_details", "File details"], parameters,
            new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true });
        if ((await dialog.Result) is { Canceled: false }) await LoadAsync();
    }
}
