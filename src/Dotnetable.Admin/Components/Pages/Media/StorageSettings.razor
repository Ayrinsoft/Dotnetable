@page "/media/storage"
@attribute [Authorize(Policy = RoleKeys.MediaUpload)]
@inject IStorageSettingService StorageService
@inject IWebsiteService WebsiteService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject AuthenticationStateProvider AuthState
@inject IPageLocalizer L

<DNPageTitle Title=@L["storage", "Storage"] />

<MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
    <MudStack Spacing="0">
        <MudText Typo="Typo.h5" Class="fw-bold">@L["storage.heading", "Storage Backends"]</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">@L["storage.subtitle", "CDN storages used by the media library"]</MudText>
    </MudStack>
    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
        @if (_isMaster)
        {
            <MudSelect T="int" Value="_websiteId" ValueChanged="OnWebsiteChanged" Label="@L["website", "Website"]"
                       Variant="Variant.Outlined" Dense="true" Style="min-width:200px;">
                @foreach (var w in _websites)
                {
                    <MudSelectItem T="int" Value="w.WebsiteID">@w.BrandName (@w.WebsiteID)</MudSelectItem>
                }
            </MudSelect>
        }
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Add" OnClick="@(() => OpenEditAsync(null))">
            @L["storage.add", "Add Storage"]
        </MudButton>
    </MudStack>
</MudStack>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-3" />
}
else if (_items.Count == 0)
{
    <MudPaper Elevation="0" Class="app-card rounded-lg pa-8" Style="text-align:center;">
        <MudIcon Icon="@Icons.Material.Filled.CloudOff" Size="Size.Large" Color="Color.Secondary" />
        <MudText Color="Color.Secondary" Class="mt-2">@L["storage.empty", "No storage configured for this website yet."]</MudText>
    </MudPaper>
}
else
{
    <MudGrid Spacing="3">
        @foreach (var s in _items)
        {
            var provider = (StorageProviderType)s.StorageProvider;
            var quota = _quotas.GetValueOrDefault(s.WebsiteStorageSettingsID);
            var pct = MediaFormat.UsedPercent(quota);
            <MudItem xs="12" sm="6" md="4">
                <MudPaper Elevation="0" Class="app-card rounded-lg pa-4" Style="height:100%;">
                    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                        <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                            <MudIcon Icon="@Icons.Material.Filled.Cloud" Color="Color.Primary" />
                            <MudText Typo="Typo.subtitle1" Class="fw-bold">@MediaFormat.ProviderLabel(provider)</MudText>
                        </MudStack>
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                                 Color="@(s.Active ? Color.Success : Color.Default)">
                            @(s.Active ? L["active", "Active"] : L["inactive", "Inactive"])
                        </MudChip>
                    </MudStack>

                    <MudDivider Class="my-3" />

                    @if (quota is not null)
                    {
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            @($"{MediaFormat.Size(quota.UsedKB)} {L["storage.used", "used"]}")@(quota.TotalKB is long t ? $" {L["storage.of", "of"]} {MediaFormat.Size(t)}" : "")
                        </MudText>
                        <MudProgressLinear Color="@(pct >= 90 ? Color.Error : Color.Info)" Class="my-1"
                                           Value="@(pct ?? 0)" />
                    }
                    else
                    {
                        <MudText Typo="Typo.caption" Color="Color.Secondary">@L["storage.quota_unavailable", "Quota unavailable."]</MudText>
                    }

                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="d-block mt-2">
                        @($"{L["storage.max", "Max"]} {MediaFormat.Size(s.MaxFileSizeKB)} · ")@(string.IsNullOrWhiteSpace(s.AllowedExtensions) ? L["storage.all_types", "all types"] : s.AllowedExtensions)
                    </MudText>

                    <MudStack Row="true" Spacing="1" Class="mt-3">
                        <MudButton Size="Size.Small" StartIcon="@Icons.Material.Filled.Edit"
                                   OnClick="@(() => OpenEditAsync(s))">@L["edit", "Edit"]</MudButton>
                        <MudButton Size="Size.Small" StartIcon="@Icons.Material.Filled.NetworkCheck"
                                   OnClick="@(() => TestAsync(s.WebsiteStorageSettingsID))">@L["storage.test", "Test"]</MudButton>
                        <MudSpacer />
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                       OnClick="@(() => DeleteAsync(s.WebsiteStorageSettingsID))" />
                    </MudStack>
                </MudPaper>
            </MudItem>
        }
    </MudGrid>
}

@code {
    private bool _isMaster;
    private int _websiteId;
    private bool _loading = true;
    private List<Website> _websites = new();
    private List<WebstieStorageSetting> _items = new();
    private Dictionary<int, StorageQuota> _quotas = new();

    protected override async Task OnInitializedAsync()
    {
        await L.EnsureLoadedAsync();

        var user = (await AuthState.GetAuthenticationStateAsync()).User;
        _isMaster = user.HasClaim(AdminClaimTypes.Master, "true");
        int.TryParse(user.FindFirst(AdminClaimTypes.WebsiteId)?.Value, out _websiteId);

        if (_isMaster)
        {
            _websites = (await WebsiteService.GetAllAsync()).ToList();
            if (_websiteId == 0 && _websites.Count > 0) _websiteId = _websites[0].WebsiteID;
        }
        await LoadAsync();
    }

    private async Task OnWebsiteChanged(int websiteId)
    {
        _websiteId = websiteId;
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _items = (await StorageService.GetForWebsiteAsync(_websiteId)).ToList();
        _quotas = new();
        _loading = false;
        StateHasChanged();

        // Quota lookups hit the network; load them after the cards render.
        foreach (var s in _items)
        {
            try { _quotas[s.WebsiteStorageSettingsID] = await StorageService.GetQuotaAsync(s.WebsiteStorageSettingsID); }
            catch { /* leave unavailable */ }
            StateHasChanged();
        }
    }

    private async Task OpenEditAsync(WebstieStorageSetting? setting)
    {
        var parameters = new DialogParameters
        {
            [nameof(StorageEditDialog.WebsiteID)] = _websiteId,
            [nameof(StorageEditDialog.Setting)] = setting,
        };
        var dialog = await DialogService.ShowAsync<StorageEditDialog>(
            setting is null ? L["storage.add", "Add Storage"] : L["storage.edit_title", "Edit Storage"], parameters,
            new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true });
        if ((await dialog.Result) is { Canceled: false }) await LoadAsync();
    }

    private async Task TestAsync(int id)
    {
        var ok = await StorageService.TestAsync(id);
        Snackbar.Add(ok ? L["storage.test_ok", "Connection succeeded."] : L["storage.test_fail", "Connection failed."], ok ? Severity.Success : Severity.Error);
    }

    private async Task DeleteAsync(int id)
    {
        var ok = await DialogService.ShowMessageBoxAsync(L["storage.delete_q", "Delete storage?"],
            L["storage.delete_body", "Files already uploaded stay on the CDN, but this storage will no longer be selectable."],
            yesText: L["delete", "Delete"], cancelText: L["cancel", "Cancel"]);
        if (ok == true)
        {
            await StorageService.DeleteAsync(id);
            Snackbar.Add(L["storage.deleted", "Storage deleted."], Severity.Success);
            await LoadAsync();
        }
    }
}
