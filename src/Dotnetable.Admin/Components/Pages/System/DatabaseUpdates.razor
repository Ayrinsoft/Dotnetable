@page "/system/updates"
@attribute [Authorize(Policy = AdminPolicies.SuperAdminOnly)]
@inject IDatabaseUpdateService UpdateService
@inject ISnackbar Snackbar

<PageTitle>Database Updates — Dotnetable</PageTitle>

@* ── Page header ──────────────────────────────────────────────── *@
<MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
    <MudStack Spacing="0">
        <MudText Typo="Typo.h5" Class="fw-bold">Database Updates</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">Manage EF Core schema migrations</MudText>
    </MudStack>
    <MudButton Variant="Variant.Outlined" Color="Color.Default"
               StartIcon="@Icons.Material.Filled.Refresh"
               OnClick="RefreshAsync" Disabled="@(_loading || _applying)">
        Refresh
    </MudButton>
</MudStack>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4" />
}
else
{
    @* ── Summary cards ────────────────────────────────────────── *@
    <MudGrid Spacing="3" Class="mb-4">
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Elevation="0" Class="border rounded-lg pa-4 d-flex align-center gap-3">
                <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Size="Size.Large" />
                <div>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Applied</MudText>
                    <MudText Typo="Typo.h5" Class="fw-bold lh-1">@_applied.Count</MudText>
                </div>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudPaper Elevation="0" Class="border rounded-lg pa-4 d-flex align-center gap-3"
                      Style="@(_pending.Count > 0 ? "border-color:var(--mud-palette-warning) !important;" : "")">
                <MudIcon Icon="@(_pending.Count > 0 ? Icons.Material.Filled.Warning : Icons.Material.Filled.Done)"
                         Color="@(_pending.Count > 0 ? Color.Warning : Color.Success)" Size="Size.Large" />
                <div>
                    <MudText Typo="Typo.caption" Color="Color.Secondary">Pending</MudText>
                    <MudText Typo="Typo.h5" Class="fw-bold lh-1"
                             Color="@(_pending.Count > 0 ? Color.Warning : Color.Success)">
                        @_pending.Count
                    </MudText>
                </div>
            </MudPaper>
        </MudItem>
    </MudGrid>

    @* ── Pending migrations ───────────────────────────────────── *@
    @if (_pending.Count > 0)
    {
        <MudPaper Elevation="0" Class="border rounded-lg pa-4 mb-4"
                  Style="border-color:var(--mud-palette-warning) !important;">
            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-3">
                <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                    <MudIcon Icon="@Icons.Material.Filled.Warning" Color="Color.Warning" />
                    <MudText Typo="Typo.subtitle1" Class="fw-bold">Pending Migrations</MudText>
                </MudStack>
                <MudButton Variant="Variant.Filled" Color="Color.Warning"
                           StartIcon="@Icons.Material.Filled.SystemUpdateAlt"
                           OnClick="ApplyAsync" Disabled="@_applying">
                    @if (_applying)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-2" />
                    }
                    Apply @_pending.Count Migration(s)
                </MudButton>
            </MudStack>
            <MudList T="string" Dense="true">
                @foreach (var name in _pending)
                {
                    <MudListItem T="string" Icon="@Icons.Material.Filled.ArrowRight" IconColor="Color.Warning">
                        <MudText Typo="Typo.body2" Class="font-monospace">@name</MudText>
                    </MudListItem>
                }
            </MudList>
        </MudPaper>
    }
    else
    {
        <MudAlert Severity="Severity.Success" Class="mb-4" Elevation="0">
            <MudText>The database schema is fully up to date.</MudText>
        </MudAlert>
    }

    @* ── Applied migrations ───────────────────────────────────── *@
    <MudPaper Elevation="0" Class="border rounded-lg">
        <div class="pa-4 border-bottom d-flex align-center gap-2">
            <MudIcon Icon="@Icons.Material.Filled.History" Color="Color.Secondary" />
            <MudText Typo="Typo.subtitle1" Class="fw-bold">Applied Migrations</MudText>
            <MudChip T="string" Size="Size.Small" Color="Color.Success" Variant="Variant.Outlined">@_applied.Count</MudChip>
        </div>
        @if (_applied.Count == 0)
        {
            <MudStack AlignItems="AlignItems.Center" Class="pa-6" Spacing="1">
                <MudText Color="Color.Secondary">No migrations applied yet.</MudText>
            </MudStack>
        }
        else
        {
            <MudList T="string" Dense="true" Class="py-2">
                @foreach (var name in _applied.AsEnumerable().Reverse())
                {
                    <MudListItem T="string" Icon="@Icons.Material.Filled.CheckCircleOutline" IconColor="Color.Success">
                        <MudText Typo="Typo.body2" Class="font-monospace">@name</MudText>
                    </MudListItem>
                }
            </MudList>
        }
    </MudPaper>
}

@code {
    private bool _loading = true;
    private bool _applying;
    private IReadOnlyList<string> _applied = [];
    private IReadOnlyList<string> _pending = [];

    protected override async Task OnInitializedAsync() => await RefreshAsync();

    private async Task RefreshAsync()
    {
        _loading = true;
        try
        {
            _applied = await UpdateService.GetAppliedUpdatesAsync();
            _pending = await UpdateService.GetPendingUpdatesAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Could not read update status: {ex.Message}", Severity.Error);
        }
        _loading = false;
    }

    private async Task ApplyAsync()
    {
        _applying = true;
        try
        {
            await UpdateService.ApplyUpdatesAsync();
            Snackbar.Add("Migrations applied successfully.", Severity.Success);
            await RefreshAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Apply failed: {ex.Message}", Severity.Error);
        }
        _applying = false;
    }
}
