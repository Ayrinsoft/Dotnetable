@page "/policies"
@attribute [Authorize(Policy = RoleKeys.PoliciesView)]
@inject IPolicyService PolicyService
@inject AuthenticationStateProvider AuthState
@inject ISnackbar Snackbar
@inject IPageLocalizer L

<DNPageTitle Title=@L["access_levels", "Access Levels"] />

<MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
    <MudStack Spacing="0">
        <MudText Typo="Typo.h5" Class="fw-bold">@L["access_levels", "Access Levels"]</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">
            @(_isMaster ? L["policy.subtitle_all", "Access levels across all websites"] : L["policy.subtitle_own", "Access levels of your website"])
        </MudText>
    </MudStack>
    <AuthorizeView Policy="@RoleKeys.PoliciesInsert" Context="ins">
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Add" Href="/policies/new">
            @L["policy.new", "New Access Level"]
        </MudButton>
    </AuthorizeView>
</MudStack>

<MudPaper Elevation="0" Class="app-card rounded-lg pa-4">
    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-3" />
    }
    <DNGridView GridHeaderParams="_grid" OnSearchChanged="OnGridChanged">
        @if (_policies.Count == 0)
        {
            <tr>
                <td colspan="@_colCount" style="text-align:center; padding:32px;">
                    <MudText Color="Color.Secondary">@L["policy.empty", "No access levels found."]</MudText>
                </td>
            </tr>
        }
        else
        {
            @foreach (var p in _policies)
            {
                <tr>
                    <td>
                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                       Color="Color.Primary" Href="@($"/policies/{p.PolicyID}")" />
                    </td>
                    <td>@p.PolicyID</td>
                    <td>@p.Title</td>
                    @if (_isMaster)
                    {
                        <td>@p.WebsiteID</td>
                    }
                    <td>
                        <MudSwitch T="bool" Value="p.Active" Color="Color.Success"
                                   Disabled="@(!_canEdit || _toggling.Contains(p.PolicyID))"
                                   ValueChanged="@(v => ToggleActiveAsync(p, v))" />
                    </td>
                </tr>
            }
        }
    </DNGridView>
</MudPaper>

@code {
    private bool _loading = true;
    private bool _isMaster;
    private bool _canEdit;
    private int _websiteId;
    private List<Policy> _policies = new();
    private HashSet<int> _toggling = new();
    private GridViewHeaderParameters _grid = new();

    private int _colCount => 4 + (_isMaster ? 1 : 0);

    protected override async Task OnInitializedAsync()
    {
        await L.EnsureLoadedAsync();

        var state = await AuthState.GetAuthenticationStateAsync();
        var user = state.User;
        _isMaster = user.HasClaim(AdminClaimTypes.Master, "true");
        _canEdit = AdminPolicies.Allows(user, RoleKeys.PoliciesEdit);
        int.TryParse(user.FindFirst(AdminClaimTypes.WebsiteId)?.Value, out _websiteId);

        _grid = new GridViewHeaderParameters
        {
            Pagination = new PaginationModel { PageSize = 25 },
            HeaderItems = new()
            {
                new() { ColumnTitle = "", ColumnName = "" },
                new() { ColumnTitle = L["id", "ID"], ColumnName = nameof(Policy.PolicyID), HasSort = true },
                new() { ColumnTitle = L["title", "Title"], ColumnName = nameof(Policy.Title), HasSort = true, HasSearch = true },
            }
        };
        if (_isMaster)
            _grid.HeaderItems.Add(new() { ColumnTitle = L["website", "Website"], ColumnName = nameof(Policy.WebsiteID), HasSort = true });
        _grid.HeaderItems.Add(new()
        {
            ColumnTitle = L["status", "Status"],
            ColumnName = nameof(Policy.Active),
            HasSearch = true,
            SearchType = SearchColumnType.DropDown,
            OtherDropDownValues = new() { [L["active", "Active"]] = "true", [L["inactive", "Inactive"]] = "false" }
        });

        await LoadAsync();
    }

    private async Task ToggleActiveAsync(Policy p, bool value)
    {
        if (!_toggling.Add(p.PolicyID)) return;
        p.Active = value;
        try { await PolicyService.SetActiveAsync(p.PolicyID, value); }
        finally { _toggling.Remove(p.PolicyID); }
    }

    private Task OnGridChanged(GridViewHeaderParameters _) => LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        var result = await PolicyService.GetPagedAsync(_isMaster ? null : _websiteId, _grid.ToQuery());
        _policies = result.Items.ToList();
        _grid.Pagination.MaxLength = result.TotalCount;
        _loading = false;
    }
}
