@page "/messages/contacts/{Id:int}"
@attribute [Authorize(Policy = RoleKeys.MessagesView)]
@inject IContactMessageService MessageService
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject IPageLocalizer L

<DNPageTitle Title=@L["contact_message", "Contact Message"] />

<MudBreadcrumbs Items="_breadcrumbs" Class="px-0 pb-2" />

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4" />
}
else if (_item is not null)
{
    <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
        <MudStack Spacing="0">
            <MudText Typo="Typo.h5" Class="fw-bold">@_item.MessageSubject</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                @($"{L["contact.from", "From"]} {_item.SenderName} — {_item.LogTime:yyyy-MM-dd HH:mm}")
            </MudText>
        </MudStack>
        <MudStack Row="true" Spacing="2">
            <MudButton Variant="Variant.Outlined" Color="@(_item.Archive ? Color.Default : Color.Primary)"
                       StartIcon="@(_item.Archive ? Icons.Material.Filled.Unarchive : Icons.Material.Filled.Archive)"
                       OnClick="ToggleArchiveAsync" Disabled="@_saving">
                @(_item.Archive ? L["unarchive", "Unarchive"] : L["archive", "Archive"])
            </MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Default"
                       StartIcon="@Icons.Material.Filled.ArrowBack" Href="/messages/contacts">
                @L["back", "Back"]
            </MudButton>
        </MudStack>
    </MudStack>

    <MudGrid Spacing="4">
        <MudItem xs="12" md="4">
            <MudPaper Elevation="0" Class="border rounded-lg pa-6">
                <MudText Typo="Typo.subtitle1" Class="fw-bold mb-3">@L["contact.sender_details", "Sender Details"]</MudText>
                <MudStack Spacing="2">
                    <div>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">@L["name", "Name"]</MudText>
                        <MudText>@_item.SenderName</MudText>
                    </div>
                    <div>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">@L["email", "Email"]</MudText>
                        <MudLink Href="@($"mailto:{_item.EmailAddress}")">@_item.EmailAddress</MudLink>
                    </div>
                    <div>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">@L["phone", "Phone"]</MudText>
                        <MudText>@(string.IsNullOrWhiteSpace(_item.CellphoneNumber) ? "—" : _item.CellphoneNumber)</MudText>
                    </div>
                    <div>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">@L["ip_address", "IP Address"]</MudText>
                        <MudText Typo="Typo.body2">@_item.SenderIPAddress</MudText>
                    </div>
                    <div>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">@L["received", "Received"]</MudText>
                        <MudText Typo="Typo.body2">@_item.LogTime.ToString("yyyy-MM-dd HH:mm:ss")</MudText>
                    </div>
                </MudStack>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="8">
            <MudPaper Elevation="0" Class="border rounded-lg pa-6" Style="min-height:200px;">
                <MudText Typo="Typo.subtitle1" Class="fw-bold mb-3">@L["message", "Message"]</MudText>
                <MudText Style="white-space: pre-wrap;">@_item.MessageBody</MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>
}

@code {
    [Parameter] public int Id { get; set; }

    private ContactUsMessage? _item;
    private bool _loading = true;
    private bool _saving;

    private List<BreadcrumbItem> _breadcrumbs => new()
    {
        new(L["dashboard", "Dashboard"], "/"),
        new(L["contact_messages", "Contact Messages"], "/messages/contacts"),
        new($"#{Id}", null, true),
    };

    protected override async Task OnInitializedAsync()
    {
        await L.EnsureLoadedAsync();

        _item = await MessageService.GetByIdAsync(Id);
        if (_item is null) Nav.NavigateTo("/messages/contacts");
        else if (!_item.Archive)
        {
            _item.Archive = false;
        }
        _loading = false;
    }

    private async Task ToggleArchiveAsync()
    {
        _saving = true;
        try
        {
            var newValue = !_item!.Archive;
            await MessageService.SetArchiveAsync(Id, newValue);
            _item.Archive = newValue;
            Snackbar.Add(newValue ? L["contact.archived", "Message archived."] : L["contact.unarchived", "Message unarchived."], Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"{L["failed", "Failed"]}: {ex.Message}", Severity.Error);
        }
        finally { _saving = false; }
    }
}
