@page "/initial-data/cities/new"
@page "/initial-data/cities/{Id:int}"
@attribute [Authorize(Policy = AdminPolicies.SuperAdminOnly)]
@inject ILocationService LocationService
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<PageTitle>@(_isNew ? "New City" : "Edit City") — Dotnetable</PageTitle>

<MudBreadcrumbs Items="_breadcrumbs" Class="px-0 pb-2" />

<MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
    <MudStack Spacing="0">
        <MudText Typo="Typo.h5" Class="fw-bold">@(_isNew ? "New City" : "Edit City")</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">
            @(_isNew ? "Add a new city to reference data" : $"Editing city #{Id}")
        </MudText>
    </MudStack>
</MudStack>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4" />
}
else if (_item is not null)
{
    <MudForm @ref="_form">
        <MudPaper Elevation="0" Class="border rounded-lg pa-6 mb-4">
            <MudGrid Spacing="3">
                <MudItem xs="12" sm="4">
                    <MudTextField @bind-Value="_item.Title" Label="City Name" Variant="Variant.Outlined"
                                  Required="true" RequiredError="City name is required." />
                </MudItem>
                <MudItem xs="12" sm="3">
                    <MudSelect T="int" @bind-Value="_item.CountryID" Label="Country"
                               Variant="Variant.Outlined" Required="true"
                               SelectedValuesChanged="OnCountryChanged">
                        @foreach (var c in _countries)
                        {
                            <MudSelectItem T="int" Value="@c.CountryID">@c.Title</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="3">
                    <MudSelect T="int?" @bind-Value="_item.StateID" Label="State (optional)"
                               Variant="Variant.Outlined" Clearable="true">
                        @foreach (var s in _states)
                        {
                            <MudSelectItem T="int?" Value="@((int?)s.StateID)">@s.Tile</MudSelectItem>
                        }
                    </MudSelect>
                </MudItem>
                <MudItem xs="12" sm="2">
                    <MudTextField @bind-Value="_item.LanguageCode" Label="Language Code"
                                  Variant="Variant.Outlined" MaxLength="2" Placeholder="fa" />
                </MudItem>
                <MudItem xs="12" sm="3">
                    <MudNumericField T="double?" @bind-Value="_item.Latitude" Label="Latitude"
                                     Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" sm="3">
                    <MudNumericField T="double" @bind-Value="_item.Longitude" Label="Longitude"
                                     Variant="Variant.Outlined" />
                </MudItem>
                <MudItem xs="12" sm="2">
                    <MudSwitch T="bool" @bind-Value="_item.Active" Color="Color.Primary"
                               Label="@(_item.Active ? "Active" : "Inactive")" />
                </MudItem>
            </MudGrid>
        </MudPaper>

        <MudStack Row="true" Spacing="2">
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Save"
                       OnClick="SaveAsync" Disabled="@_saving">
                @if (_saving)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-2" />
                }
                @(_isNew ? "Create City" : "Save Changes")
            </MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Default"
                       StartIcon="@Icons.Material.Filled.ArrowBack"
                       Href="/initial-data/cities">
                Cancel
            </MudButton>
        </MudStack>
    </MudForm>
}

@code {
    [Parameter] public int Id { get; set; }

    private MudForm _form = null!;
    private City? _item;
    private List<Country> _countries = new();
    private List<State> _states = new();
    private bool _loading = true;
    private bool _saving;
    private bool _isNew => Id == 0;

    private List<BreadcrumbItem> _breadcrumbs => new()
    {
        new("Dashboard", "/"),
        new("Cities", "/initial-data/cities"),
        new(_isNew ? "New" : $"#{Id}", null, true),
    };

    protected override async Task OnInitializedAsync()
    {
        _countries = (await LocationService.GetAllCountriesAsync()).ToList();

        if (_isNew)
        {
            var firstCountry = _countries.FirstOrDefault();
            _item = new City
            {
                Title = string.Empty,
                LanguageCode = "en",
                Active = true,
                CountryID = firstCountry?.CountryID ?? 0,
                Longitude = 0,
            };
            if (firstCountry is not null)
                _states = (await LocationService.GetStatesByCountryAsync(firstCountry.CountryID)).ToList();
        }
        else
        {
            _item = await LocationService.GetCityByIdAsync(Id);
            if (_item is null) { Nav.NavigateTo("/initial-data/cities"); return; }
            _states = (await LocationService.GetStatesByCountryAsync(_item.CountryID)).ToList();
        }
        _loading = false;
    }

    private async Task OnCountryChanged(IEnumerable<int> _)
    {
        _item!.StateID = null;
        _states = (await LocationService.GetStatesByCountryAsync(_item.CountryID)).ToList();
    }

    private async Task SaveAsync()
    {
        await _form.ValidateAsync();
        if (!_form.IsValid) return;

        _saving = true;
        try
        {
            if (_isNew)
            {
                await LocationService.CreateCityAsync(_item!);
                Snackbar.Add("City created successfully.", Severity.Success);
            }
            else
            {
                await LocationService.UpdateCityAsync(_item!);
                Snackbar.Add("Changes saved successfully.", Severity.Success);
            }
            Nav.NavigateTo("/initial-data/cities");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Save failed: {ex.Message}", Severity.Error);
        }
        finally { _saving = false; }
    }
}
