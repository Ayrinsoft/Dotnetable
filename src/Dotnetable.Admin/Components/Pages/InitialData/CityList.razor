@page "/initial-data/cities"
@attribute [Authorize(Policy = AdminPolicies.SuperAdminOnly)]
@inject ILocationService LocationService
@inject ISnackbar Snackbar
@inject IPageLocalizer L

<DNPageTitle Title=@L["cities", "Cities"] />

<MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
    <MudStack Spacing="0">
        <MudText Typo="Typo.h5" Class="fw-bold">@L["cities", "Cities"]</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">@L["city.subtitle", "Manage city reference data"]</MudText>
    </MudStack>
    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
        <MudSelect T="int?" Value="_filterCountryId" ValueChanged="OnCountryFilterChanged"
                   Label="@L["country", "Country"]" Variant="Variant.Outlined" Dense="true" Style="min-width:160px"
                   Clearable="true">
            @foreach (var c in _countries)
            {
                <MudSelectItem T="int?" Value="@((int?)c.CountryID)">@c.Title</MudSelectItem>
            }
        </MudSelect>
        <MudSelect T="int?" Value="_filterStateId" ValueChanged="OnStateFilterChanged"
                   Label="@L["state", "State"]" Variant="Variant.Outlined" Dense="true" Style="min-width:160px"
                   Clearable="true" Disabled="@(!_filterCountryId.HasValue)">
            @foreach (var s in _states)
            {
                <MudSelectItem T="int?" Value="@((int?)s.StateID)">@s.Tile</MudSelectItem>
            }
        </MudSelect>
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Add"
                   Href="/initial-data/cities/new">
            @L["city.new", "New City"]
        </MudButton>
    </MudStack>
</MudStack>

<MudPaper Elevation="0" Class="app-card rounded-lg pa-4">
    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-3" />
    }
    <DNGridView GridHeaderParams="_grid" OnSearchChanged="OnGridChanged">
        @if (_items.Count == 0)
        {
            <tr>
                <td colspan="7" style="text-align:center; padding:32px;">
                    <MudText Color="Color.Secondary">@L["city.empty", "No cities found."]</MudText>
                </td>
            </tr>
        }
        else
        {
            @foreach (var c in _items)
            {
                <tr>
                    <td>
                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                       Color="Color.Primary" Href="@($"/initial-data/cities/{c.CityID}")" />
                    </td>
                    <td>@c.CityID</td>
                    <td>@c.Title</td>
                    <td>@(c.Country?.Title ?? c.CountryID.ToString())</td>
                    <td>@(c.State?.Tile ?? "-")</td>
                    <td>@c.LanguageCode</td>
                    <td>
                        <MudSwitch T="bool" Value="c.Active" Color="Color.Success"
                                   Disabled="_toggling.Contains(c.CityID)"
                                   ValueChanged="@(v => ToggleActiveAsync(c, v))" />
                    </td>
                </tr>
            }
        }
    </DNGridView>
</MudPaper>

@code {
    private bool _loading = true;
    private int? _filterCountryId;
    private int? _filterStateId;
    private List<City> _items = new();
    private List<Country> _countries = new();
    private List<State> _states = new();
    private HashSet<int> _toggling = new();
    private GridViewHeaderParameters _grid = new();

    protected override async Task OnInitializedAsync()
    {
        await L.EnsureLoadedAsync();

        _countries = (await LocationService.GetAllCountriesAsync()).ToList();

        _grid = new GridViewHeaderParameters
        {
            Pagination = new PaginationModel { PageSize = 25 },
            HeaderItems = new()
            {
                new() { ColumnTitle = "", ColumnName = "" },
                new() { ColumnTitle = L["id", "ID"], ColumnName = nameof(City.CityID), HasSort = true },
                new() { ColumnTitle = L["title", "Title"], ColumnName = nameof(City.Title), HasSort = true, HasSearch = true },
                new() { ColumnTitle = L["country", "Country"], ColumnName = "" },
                new() { ColumnTitle = L["state", "State"], ColumnName = "" },
                new() { ColumnTitle = L["language", "Language"], ColumnName = nameof(City.LanguageCode) },
                new() { ColumnTitle = L["active", "Active"], ColumnName = nameof(City.Active), HasSearch = true,
                    SearchType = SearchColumnType.DropDown,
                    OtherDropDownValues = new() { [L["active", "Active"]] = "true", [L["inactive", "Inactive"]] = "false" } },
            }
        };

        await LoadAsync();
    }

    private Task OnGridChanged(GridViewHeaderParameters _) => LoadAsync();

    private async Task OnCountryFilterChanged(int? countryId)
    {
        _filterCountryId = countryId;
        _filterStateId = null;
        _states = countryId.HasValue
            ? (await LocationService.GetStatesByCountryAsync(countryId.Value)).ToList()
            : new();
        await LoadAsync();
    }

    private async Task OnStateFilterChanged(int? stateId)
    {
        _filterStateId = stateId;
        await LoadAsync();
    }

    private async Task ToggleActiveAsync(City c, bool value)
    {
        if (!_toggling.Add(c.CityID)) return;
        c.Active = value;
        try
        {
            var entity = await LocationService.GetCityByIdAsync(c.CityID);
            if (entity is not null)
            {
                entity.Active = value;
                await LocationService.UpdateCityAsync(entity);
            }
        }
        finally { _toggling.Remove(c.CityID); }
    }

    private async Task LoadAsync()
    {
        _loading = true;
        var result = await LocationService.GetCitiesPagedAsync(_filterCountryId, _filterStateId, _grid.ToQuery());
        _items = result.Items.ToList();
        _grid.Pagination.MaxLength = result.TotalCount;
        _loading = false;
    }
}
