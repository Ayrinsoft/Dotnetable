@page "/website/scripts"
@attribute [Authorize(Policy = AdminPolicies.WebsiteAdminOrAbove)]
@inject IWebsiteSettingService SettingService
@inject IWebsiteService WebsiteService
@inject AuthenticationStateProvider AuthState
@inject ISnackbar Snackbar
@inject IPageLocalizer L

<DNPageTitle Title=@L["scripts", "Scripts"] />

<MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
    <MudStack Spacing="0">
        <MudText Typo="Typo.h5" Class="fw-bold">@L["scripts", "Scripts"]</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">@L["script.subtitle", "Custom scripts injected into website pages (Google Analytics, Tag Manager, etc.)"]</MudText>
    </MudStack>
    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
        @if (_isMaster)
        {
            <MudSelect T="int" @bind-Value="_websiteId" Label="@L["website", "Website"]" Variant="Variant.Outlined"
                       Dense="true" Style="min-width:180px"
                       SelectedValuesChanged="OnWebsiteChanged">
                @foreach (var w in _websites)
                {
                    <MudSelectItem T="int" Value="@w.WebsiteID">@w.TradeName</MudSelectItem>
                }
            </MudSelect>
        }
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Add"
                   Href="/website/scripts/new">
            @L["script.new", "New Script"]
        </MudButton>
    </MudStack>
</MudStack>

<MudPaper Elevation="0" Class="app-card rounded-lg pa-4">
    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-3" />
    }
    <DNGridView GridHeaderParams="_grid" OnSearchChanged="OnGridChanged">
        @if (_items.Count == 0)
        {
            <tr>
                <td colspan="5" style="text-align:center; padding:32px;">
                    <MudText Color="Color.Secondary">@L["script.empty", "No scripts defined."]</MudText>
                </td>
            </tr>
        }
        else
        {
            @foreach (var s in _items)
            {
                <tr>
                    <td>
                        <MudStack Row="true" Spacing="1">
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                           Color="Color.Primary" Href="@($"/website/scripts/{s.WebsiteScriptID}")" />
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                           Color="Color.Error" OnClick="@(() => DeleteAsync(s))" />
                        </MudStack>
                    </td>
                    <td>@s.Name</td>
                    <td>@ScriptPositionLabel(s.ScriptPosition)</td>
                    <td>@(s.Priority.HasValue ? s.Priority.ToString() : "-")</td>
                    <td>
                        <MudSwitch T="bool" Value="s.Active" Color="Color.Success"
                                   Disabled="_toggling.Contains(s.WebsiteScriptID)"
                                   ValueChanged="@(v => ToggleActiveAsync(s, v))" />
                    </td>
                </tr>
            }
        }
    </DNGridView>
</MudPaper>

@code {
    private bool _loading = true;
    private bool _isMaster;
    private int _websiteId;
    private List<WebsiteScript> _items = new();
    private List<Website> _websites = new();
    private HashSet<int> _toggling = new();
    private GridViewHeaderParameters _grid = new();

    protected override async Task OnInitializedAsync()
    {
        await L.EnsureLoadedAsync();

        var state = await AuthState.GetAuthenticationStateAsync();
        var user = state.User;
        _isMaster = user.HasClaim(AdminClaimTypes.Master, "true");
        int.TryParse(user.FindFirst(AdminClaimTypes.WebsiteId)?.Value, out _websiteId);

        if (_isMaster)
            _websites = (await WebsiteService.GetAllAsync()).ToList();

        _grid = new GridViewHeaderParameters
        {
            Pagination = new PaginationModel { PageSize = 25 },
            HeaderItems = new()
            {
                new() { ColumnTitle = "", ColumnName = "" },
                new() { ColumnTitle = L["name", "Name"], ColumnName = nameof(WebsiteScript.Name), HasSort = true, HasSearch = true },
                new() { ColumnTitle = L["position", "Position"], ColumnName = "" },
                new() { ColumnTitle = L["priority", "Priority"], ColumnName = nameof(WebsiteScript.Priority), HasSort = true },
                new() { ColumnTitle = L["active", "Active"], ColumnName = nameof(WebsiteScript.Active), HasSearch = true,
                    SearchType = SearchColumnType.DropDown,
                    OtherDropDownValues = new() { [L["active", "Active"]] = "true", [L["inactive", "Inactive"]] = "false" } },
            }
        };

        await LoadAsync();
    }

    private Task OnGridChanged(GridViewHeaderParameters _) => LoadAsync();

    private async Task OnWebsiteChanged(IEnumerable<int> _) => await LoadAsync();

    private async Task ToggleActiveAsync(WebsiteScript s, bool value)
    {
        if (!_toggling.Add(s.WebsiteScriptID)) return;
        s.Active = value;
        try { await SettingService.SetScriptActiveAsync(s.WebsiteScriptID, value); }
        finally { _toggling.Remove(s.WebsiteScriptID); }
    }

    private async Task DeleteAsync(WebsiteScript s)
    {
        await SettingService.DeleteScriptAsync(s.WebsiteScriptID);
        Snackbar.Add(L["script.deleted", "Script deleted."], Severity.Success);
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        var result = await SettingService.GetScriptsPagedAsync(_websiteId, _grid.ToQuery());
        _items = result.Items.ToList();
        _grid.Pagination.MaxLength = result.TotalCount;
        _loading = false;
    }

    private string ScriptPositionLabel(byte pos) => pos switch
    {
        0 => L["script.pos_head", "Head"],
        1 => L["script.pos_body_start", "Body Start"],
        2 => L["script.pos_body_end", "Body End"],
        _ => pos.ToString()
    };
}
