@page "/website/ips"
@attribute [Authorize(Policy = AdminPolicies.WebsiteAdminOrAbove)]
@inject IWebsiteSettingService SettingService
@inject IWebsiteService WebsiteService
@inject AuthenticationStateProvider AuthState
@inject ISnackbar Snackbar

<PageTitle>IP Whitelist — Dotnetable</PageTitle>

<MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
    <MudStack Spacing="0">
        <MudText Typo="Typo.h5" Class="fw-bold">IP Whitelist</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">
            Define allowed IP addresses or ranges. Maximum 5 entries per website.
        </MudText>
    </MudStack>
    <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
        @if (_isMaster)
        {
            <MudSelect T="int" @bind-Value="_websiteId" Label="Website" Variant="Variant.Outlined"
                       Dense="true" Style="min-width:180px"
                       SelectedValuesChanged="OnWebsiteChanged">
                @foreach (var w in _websites)
                {
                    <MudSelectItem T="int" Value="@w.WebsiteID">@w.TradeName</MudSelectItem>
                }
            </MudSelect>
        }
        <MudButton Variant="Variant.Filled" Color="Color.Primary"
                   StartIcon="@Icons.Material.Filled.Add"
                   OnClick="OpenAddDialog"
                   Disabled="@(_ipCount >= 5)">
            Add IP / Range
        </MudButton>
    </MudStack>
</MudStack>

@if (_ipCount >= 5)
{
    <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-3">
        This website has reached the maximum of 5 IP entries.
    </MudAlert>
}

<MudPaper Elevation="0" Class="app-card rounded-lg pa-4">
    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-3" />
    }
    <DNGridView GridHeaderParams="_grid" OnSearchChanged="OnGridChanged">
        @if (_items.Count == 0)
        {
            <tr>
                <td colspan="6" style="text-align:center; padding:32px;">
                    <MudText Color="Color.Secondary">No IP entries defined.</MudText>
                </td>
            </tr>
        }
        else
        {
            @foreach (var ip in _items)
            {
                <tr>
                    <td>
                        <MudStack Row="true" Spacing="1">
                            <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                           Color="Color.Primary" OnClick="@(() => OpenEditDialog(ip))" />
                            <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small"
                                           Color="Color.Error" OnClick="@(() => DeleteAsync(ip))" />
                        </MudStack>
                    </td>
                    <td>@ip.Label</td>
                    <td>@ip.StartIP</td>
                    <td>@(ip.EndIP ?? "-")</td>
                    <td>@(ip.CidrPrefix.HasValue ? $"/{ip.CidrPrefix}" : "-")</td>
                    <td>
                        <MudSwitch T="bool" Value="ip.Active" Color="Color.Success"
                                   Disabled="_toggling.Contains(ip.WebsiteIPID)"
                                   ValueChanged="@(v => ToggleActiveAsync(ip, v))" />
                    </td>
                </tr>
            }
        }
    </DNGridView>
</MudPaper>

@* ── Add / Edit Dialog ────────────────────────────────────────────── *@
<MudDialog @bind-Visible="_dialogOpen" Options="@(new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true })">
    <TitleContent>
        <MudText Typo="Typo.h6">@(_editItem?.WebsiteIPID == 0 ? "Add IP Entry" : "Edit IP Entry")</MudText>
    </TitleContent>
    <DialogContent>
        @if (_editItem is not null)
        {
            <MudForm @ref="_form">
                <MudGrid Spacing="2">
                    <MudItem xs="12">
                        <MudTextField @bind-Value="_editItem.Label" Label="Label / Description"
                                      Variant="Variant.Outlined" Required="true"
                                      RequiredError="Label is required." />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="_editItem.StartIP" Label="Start IP / Single IP"
                                      Variant="Variant.Outlined" Required="true"
                                      RequiredError="IP address is required."
                                      Placeholder="192.168.1.1" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="_editItem.EndIP" Label="End IP (for range)"
                                      Variant="Variant.Outlined" Placeholder="192.168.1.254" />
                    </MudItem>
                    <MudItem xs="12" sm="4">
                        <MudNumericField T="int?" @bind-Value="_editItem.CidrPrefix" Label="CIDR Prefix"
                                         Variant="Variant.Outlined" Min="0" Max="32" Placeholder="24" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudSwitch T="bool" @bind-Value="_editItem.Active" Color="Color.Primary" Label="Active" />
                    </MudItem>
                </MudGrid>
            </MudForm>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="@(() => _dialogOpen = false)" Variant="Variant.Text">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled"
                   OnClick="SaveDialogAsync" Disabled="@_saving">
            @if (_saving) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-2" /> }
            Save
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    private bool _loading = true;
    private bool _isMaster;
    private int _websiteId;
    private int _ipCount;
    private List<WebsiteIP> _items = new();
    private List<Website> _websites = new();
    private HashSet<int> _toggling = new();
    private GridViewHeaderParameters _grid = new();

    private bool _dialogOpen;
    private bool _saving;
    private WebsiteIP? _editItem;
    private MudForm _form = null!;

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthState.GetAuthenticationStateAsync();
        var user = state.User;
        _isMaster = user.HasClaim(AdminClaimTypes.Master, "true");
        int.TryParse(user.FindFirst(AdminClaimTypes.WebsiteId)?.Value, out _websiteId);

        if (_isMaster)
            _websites = (await WebsiteService.GetAllAsync()).ToList();

        _grid = new GridViewHeaderParameters
        {
            Pagination = new PaginationModel { PageSize = 25 },
            HeaderItems = new()
            {
                new() { ColumnTitle = "", ColumnName = "" },
                new() { ColumnTitle = "Label", ColumnName = nameof(WebsiteIP.Label), HasSearch = true },
                new() { ColumnTitle = "Start IP", ColumnName = nameof(WebsiteIP.StartIP), HasSearch = true },
                new() { ColumnTitle = "End IP", ColumnName = "" },
                new() { ColumnTitle = "CIDR", ColumnName = "" },
                new() { ColumnTitle = "Active", ColumnName = nameof(WebsiteIP.Active), HasSearch = true,
                    SearchType = SearchColumnType.DropDown,
                    OtherDropDownValues = new() { ["Active"] = "true", ["Inactive"] = "false" } },
            }
        };

        await LoadAsync();
    }

    private Task OnGridChanged(GridViewHeaderParameters _) => LoadAsync();

    private async Task OnWebsiteChanged(IEnumerable<int> _) => await LoadAsync();

    private async Task ToggleActiveAsync(WebsiteIP ip, bool value)
    {
        if (!_toggling.Add(ip.WebsiteIPID)) return;
        ip.Active = value;
        try { await SettingService.SetIPActiveAsync(ip.WebsiteIPID, value); }
        finally { _toggling.Remove(ip.WebsiteIPID); }
    }

    private void OpenAddDialog()
    {
        _editItem = new WebsiteIP { WebsiteIPID = 0, WebsiteID = _websiteId, Label = string.Empty, StartIP = string.Empty, Active = true };
        _dialogOpen = true;
    }

    private void OpenEditDialog(WebsiteIP ip)
    {
        _editItem = new WebsiteIP
        {
            WebsiteIPID = ip.WebsiteIPID,
            WebsiteID = ip.WebsiteID,
            Label = ip.Label,
            StartIP = ip.StartIP,
            EndIP = ip.EndIP,
            CidrPrefix = ip.CidrPrefix,
            Active = ip.Active,
        };
        _dialogOpen = true;
    }

    private async Task SaveDialogAsync()
    {
        await _form.ValidateAsync();
        if (!_form.IsValid) return;

        _saving = true;
        try
        {
            if (_editItem!.WebsiteIPID == 0)
            {
                _editItem.WebsiteID = _websiteId;
                await SettingService.CreateIPAsync(_editItem);
                Snackbar.Add("IP entry added.", Severity.Success);
            }
            else
            {
                await SettingService.UpdateIPAsync(_editItem);
                Snackbar.Add("IP entry updated.", Severity.Success);
            }
            _dialogOpen = false;
            await LoadAsync();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Save failed: {ex.Message}", Severity.Error);
        }
        finally { _saving = false; }
    }

    private async Task DeleteAsync(WebsiteIP ip)
    {
        await SettingService.DeleteIPAsync(ip.WebsiteIPID);
        Snackbar.Add("IP entry deleted.", Severity.Success);
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        var result = await SettingService.GetIPsPagedAsync(_websiteId, _grid.ToQuery());
        _items = result.Items.ToList();
        _grid.Pagination.MaxLength = result.TotalCount;
        _ipCount = await SettingService.GetIPCountAsync(_websiteId);
        _loading = false;
    }
}
