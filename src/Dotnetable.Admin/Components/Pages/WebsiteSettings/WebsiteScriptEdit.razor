@page "/website/scripts/new"
@page "/website/scripts/{Id:int}"
@attribute [Authorize(Policy = RoleKeys.WebsiteEdit)]
@inject IWebsiteSettingService SettingService
@inject AuthenticationStateProvider AuthState
@inject NavigationManager Nav
@inject ISnackbar Snackbar
@inject IPageLocalizer L

<DNPageTitle Title=@(_isNew ? L["script.new", "New Script"] : L["script.edit", "Edit Script"]) />

<MudBreadcrumbs Items="_breadcrumbs" Class="px-0 pb-2" />

<MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
    <MudStack Spacing="0">
        <MudText Typo="Typo.h5" Class="fw-bold">@(_isNew ? L["script.new", "New Script"] : L["script.edit", "Edit Script"])</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">
            @(_isNew ? L["script.new_subtitle", "Add a custom script to your website"] : $"{L["script.editing", "Editing script"]} #{Id}")
        </MudText>
    </MudStack>
</MudStack>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4" />
}
else if (_item is not null)
{
    <MudForm @ref="_form">
        <MudGrid Spacing="4">
            <MudItem xs="12">
                <MudPaper Elevation="0" Class="border rounded-lg pa-6">
                    <MudGrid Spacing="3">
                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="_item.Name" Label="@L["script.name", "Script Name"]"
                                          Variant="Variant.Outlined" Required="true"
                                          RequiredError="@L["required", "This field is required."]"
                                          Placeholder="Google Analytics" />
                        </MudItem>
                        <MudItem xs="12" sm="3">
                            <MudSelect T="byte" @bind-Value="_item.ScriptPosition" Label="@L["position", "Position"]"
                                       Variant="Variant.Outlined">
                                <MudSelectItem T="byte" Value="@((byte)0)">@L["script.pos_head", "Head"]</MudSelectItem>
                                <MudSelectItem T="byte" Value="@((byte)1)">@L["script.pos_body_start", "Body Start"]</MudSelectItem>
                                <MudSelectItem T="byte" Value="@((byte)2)">@L["script.pos_body_end", "Body End"]</MudSelectItem>
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" sm="3">
                            <MudSelect T="byte" @bind-Value="_item.ScriptLoadCondition" Label="@L["script.load_condition", "Load Condition"]"
                                       Variant="Variant.Outlined">
                                <MudSelectItem T="byte" Value="@((byte)0)">@L["script.cond_always", "Always"]</MudSelectItem>
                                <MudSelectItem T="byte" Value="@((byte)1)">@L["script.cond_in", "Logged In Only"]</MudSelectItem>
                                <MudSelectItem T="byte" Value="@((byte)2)">@L["script.cond_out", "Logged Out Only"]</MudSelectItem>
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" sm="2">
                            <MudNumericField T="byte?" @bind-Value="_item.Priority" Label="@L["priority", "Priority"]"
                                             Variant="Variant.Outlined" Min="0" Max="255"
                                             HelperText="@L["script.priority_hint", "Lower = earlier"]" />
                        </MudItem>
                        <MudItem xs="12">
                            <MudTextField @bind-Value="_item.RawContent" Label="@L["script.content", "Script Content"]"
                                          Variant="Variant.Outlined" Lines="10"
                                          Required="true" RequiredError="@L["required", "This field is required."]"
                                          Placeholder="@("<script>...</script>")"
                                          Style="font-family: monospace; font-size: 13px;" />
                        </MudItem>
                        <MudItem xs="12">
                            <MudSwitch T="bool" @bind-Value="_item.Active" Color="Color.Primary"
                                       Label="@(_item.Active ? L["script.active_on", "Active — will be injected"] : L["script.active_off", "Inactive — will not be injected"])" />
                        </MudItem>
                    </MudGrid>
                </MudPaper>
            </MudItem>
        </MudGrid>

        <MudStack Row="true" Class="mt-4" Spacing="2">
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Save"
                       OnClick="SaveAsync" Disabled="@_saving">
                @if (_saving)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-2" />
                }
                @(_isNew ? L["script.create", "Create Script"] : L["save", "Save Changes"])
            </MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Default"
                       StartIcon="@Icons.Material.Filled.ArrowBack" Href="/website/scripts">
                @L["cancel", "Cancel"]
            </MudButton>
        </MudStack>
    </MudForm>
}

@code {
    [Parameter] public int Id { get; set; }

    private MudForm _form = null!;
    private WebsiteScript? _item;
    private bool _loading = true;
    private bool _saving;
    private int _websiteId;
    private bool _isNew => Id == 0;

    private List<BreadcrumbItem> _breadcrumbs => new()
    {
        new(L["dashboard", "Dashboard"], "/"),
        new(L["scripts", "Scripts"], "/website/scripts"),
        new(_isNew ? L["new", "New"] : $"#{Id}", null, true),
    };

    protected override async Task OnInitializedAsync()
    {
        await L.EnsureLoadedAsync();

        var state = await AuthState.GetAuthenticationStateAsync();
        int.TryParse(state.User.FindFirst(AdminClaimTypes.WebsiteId)?.Value, out _websiteId);

        if (_isNew)
        {
            _item = new WebsiteScript
            {
                WebsiteID = _websiteId,
                Name = string.Empty,
                RawContent = string.Empty,
                ScriptPosition = 0,
                ScriptLoadCondition = 0,
                Active = true,
                LogTime = DateTime.UtcNow,
            };
        }
        else
        {
            _item = await SettingService.GetScriptByIdAsync(Id);
            if (_item is null || _item.WebsiteID != _websiteId)
                Nav.NavigateTo("/website/scripts");
        }
        _loading = false;
    }

    private async Task SaveAsync()
    {
        await _form.ValidateAsync();
        if (!_form.IsValid) return;

        _saving = true;
        try
        {
            if (_isNew)
            {
                await SettingService.CreateScriptAsync(_item!);
                Snackbar.Add(L["script.created", "Script created."], Severity.Success);
            }
            else
            {
                await SettingService.UpdateScriptAsync(_item!);
                Snackbar.Add(L["script.updated", "Script updated."], Severity.Success);
            }
            Nav.NavigateTo("/website/scripts");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"{L["save_failed", "Save failed"]}: {ex.Message}", Severity.Error);
        }
        finally { _saving = false; }
    }
}
