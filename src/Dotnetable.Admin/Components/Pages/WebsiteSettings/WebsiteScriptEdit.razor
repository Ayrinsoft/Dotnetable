@page "/website/scripts/new"
@page "/website/scripts/{Id:int}"
@attribute [Authorize(Policy = AdminPolicies.WebsiteAdminOrAbove)]
@inject IWebsiteSettingService SettingService
@inject AuthenticationStateProvider AuthState
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<PageTitle>@(_isNew ? "New Script" : "Edit Script") — Dotnetable</PageTitle>

<MudBreadcrumbs Items="_breadcrumbs" Class="px-0 pb-2" />

<MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
    <MudStack Spacing="0">
        <MudText Typo="Typo.h5" Class="fw-bold">@(_isNew ? "New Script" : "Edit Script")</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">
            @(_isNew ? "Add a custom script to your website" : $"Editing script #{Id}")
        </MudText>
    </MudStack>
</MudStack>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4" />
}
else if (_item is not null)
{
    <MudForm @ref="_form">
        <MudGrid Spacing="4">
            <MudItem xs="12">
                <MudPaper Elevation="0" Class="border rounded-lg pa-6">
                    <MudGrid Spacing="3">
                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="_item.Name" Label="Script Name"
                                          Variant="Variant.Outlined" Required="true"
                                          RequiredError="Name is required."
                                          Placeholder="Google Analytics" />
                        </MudItem>
                        <MudItem xs="12" sm="3">
                            <MudSelect T="byte" @bind-Value="_item.ScriptPosition" Label="Position"
                                       Variant="Variant.Outlined">
                                <MudSelectItem T="byte" Value="@((byte)0)">Head</MudSelectItem>
                                <MudSelectItem T="byte" Value="@((byte)1)">Body Start</MudSelectItem>
                                <MudSelectItem T="byte" Value="@((byte)2)">Body End</MudSelectItem>
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" sm="3">
                            <MudSelect T="byte" @bind-Value="_item.ScriptLoadCondition" Label="Load Condition"
                                       Variant="Variant.Outlined">
                                <MudSelectItem T="byte" Value="@((byte)0)">Always</MudSelectItem>
                                <MudSelectItem T="byte" Value="@((byte)1)">Logged In Only</MudSelectItem>
                                <MudSelectItem T="byte" Value="@((byte)2)">Logged Out Only</MudSelectItem>
                            </MudSelect>
                        </MudItem>
                        <MudItem xs="12" sm="2">
                            <MudNumericField T="byte?" @bind-Value="_item.Priority" Label="Priority"
                                             Variant="Variant.Outlined" Min="0" Max="255"
                                             HelperText="Lower = earlier" />
                        </MudItem>
                        <MudItem xs="12">
                            <MudTextField @bind-Value="_item.RawContent" Label="Script Content"
                                          Variant="Variant.Outlined" Lines="10"
                                          Required="true" RequiredError="Script content is required."
                                          Placeholder="@("<script>...</script>")"
                                          Style="font-family: monospace; font-size: 13px;" />
                        </MudItem>
                        <MudItem xs="12">
                            <MudSwitch T="bool" @bind-Value="_item.Active" Color="Color.Primary"
                                       Label="@(_item.Active ? "Active — will be injected" : "Inactive — will not be injected")" />
                        </MudItem>
                    </MudGrid>
                </MudPaper>
            </MudItem>
        </MudGrid>

        <MudStack Row="true" Class="mt-4" Spacing="2">
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Save"
                       OnClick="SaveAsync" Disabled="@_saving">
                @if (_saving)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-2" />
                }
                @(_isNew ? "Create Script" : "Save Changes")
            </MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Default"
                       StartIcon="@Icons.Material.Filled.ArrowBack" Href="/website/scripts">
                Cancel
            </MudButton>
        </MudStack>
    </MudForm>
}

@code {
    [Parameter] public int Id { get; set; }

    private MudForm _form = null!;
    private WebsiteScript? _item;
    private bool _loading = true;
    private bool _saving;
    private int _websiteId;
    private bool _isNew => Id == 0;

    private List<BreadcrumbItem> _breadcrumbs => new()
    {
        new("Dashboard", "/"),
        new("Scripts", "/website/scripts"),
        new(_isNew ? "New" : $"#{Id}", null, true),
    };

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthState.GetAuthenticationStateAsync();
        int.TryParse(state.User.FindFirst(AdminClaimTypes.WebsiteId)?.Value, out _websiteId);

        if (_isNew)
        {
            _item = new WebsiteScript
            {
                WebsiteID = _websiteId,
                Name = string.Empty,
                RawContent = string.Empty,
                ScriptPosition = 0,
                ScriptLoadCondition = 0,
                Active = true,
                LogTime = DateTime.UtcNow,
            };
        }
        else
        {
            _item = await SettingService.GetScriptByIdAsync(Id);
            if (_item is null || _item.WebsiteID != _websiteId)
                Nav.NavigateTo("/website/scripts");
        }
        _loading = false;
    }

    private async Task SaveAsync()
    {
        await _form.ValidateAsync();
        if (!_form.IsValid) return;

        _saving = true;
        try
        {
            if (_isNew)
            {
                await SettingService.CreateScriptAsync(_item!);
                Snackbar.Add("Script created.", Severity.Success);
            }
            else
            {
                await SettingService.UpdateScriptAsync(_item!);
                Snackbar.Add("Script updated.", Severity.Success);
            }
            Nav.NavigateTo("/website/scripts");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Save failed: {ex.Message}", Severity.Error);
        }
        finally { _saving = false; }
    }
}
