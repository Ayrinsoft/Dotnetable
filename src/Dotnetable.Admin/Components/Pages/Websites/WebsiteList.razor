@page "/websites"
@attribute [Authorize(Policy = AdminPolicies.SuperAdminOnly)]
@inject IWebsiteService WebsiteService
@inject ISnackbar Snackbar
@inject IPageLocalizer L

<DNPageTitle Title=@L["websites", "Websites"] />

@* ── Page header ──────────────────────────────────────────────── *@
<MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
    <MudStack Spacing="0">
        <MudText Typo="Typo.h5" Class="fw-bold">@L["websites", "Websites"]</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">@L["website.subtitle", "Manage all registered websites"]</MudText>
    </MudStack>
    <MudButton Variant="Variant.Filled" Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.Add"
               Href="/websites/new">
        @L["website.new", "New Website"]
    </MudButton>
</MudStack>

<MudPaper Elevation="0" Class="app-card rounded-lg pa-4">
    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-3" />
    }
    <DNGridView GridHeaderParams="_grid" OnSearchChanged="OnGridChanged">
        @if (_websites.Count == 0)
        {
            <tr>
                <td colspan="8" style="text-align:center; padding:32px;">
                    <MudText Color="Color.Secondary">@L["website.empty", "No websites found."]</MudText>
                </td>
            </tr>
        }
        else
        {
            @foreach (var w in _websites)
            {
                <tr>
                    <td>
                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                       Color="Color.Primary" Href="@($"/websites/{w.WebsiteID}")" />
                    </td>
                    <td>@w.WebsiteID</td>
                    <td>@w.TradeName</td>
                    <td>@w.BrandName</td>
                    <td>@w.WebsiteAddress</td>
                    <td>@w.Manager</td>
                    <td>
                        @if (w.WebsiteType == 1)
                        {
                            <MudChip T="string" Color="Color.Warning" Size="Size.Small" Variant="Variant.Outlined">@L["store", "Store"]</MudChip>
                        }
                        else
                        {
                            <MudChip T="string" Color="Color.Primary" Size="Size.Small" Variant="Variant.Outlined">@L["website", "Website"]</MudChip>
                        }
                    </td>
                    <td>
                        <MudSwitch T="bool" Value="w.Active" Color="Color.Success"
                                   Disabled="_toggling.Contains(w.WebsiteID)"
                                   ValueChanged="@(v => ToggleActiveAsync(w, v))" />
                    </td>
                </tr>
            }
        }
    </DNGridView>
</MudPaper>

@code {
    private bool _loading = true;
    private List<Website> _websites = new();
    private HashSet<int> _toggling = new();
    private GridViewHeaderParameters _grid = new();

    private async Task ToggleActiveAsync(Website w, bool value)
    {
        if (!_toggling.Add(w.WebsiteID)) return;
        w.Active = value;
        try { await WebsiteService.SetActiveAsync(w.WebsiteID, value); }
        finally { _toggling.Remove(w.WebsiteID); }
    }

    protected override async Task OnInitializedAsync()
    {
        await L.EnsureLoadedAsync();

        _grid = new GridViewHeaderParameters
        {
            Pagination = new PaginationModel { PageSize = 25 },
            HeaderItems = new()
            {
                new() { ColumnTitle = "", ColumnName = "" },
                new() { ColumnTitle = L["id", "ID"], ColumnName = nameof(Website.WebsiteID), HasSort = true },
                new() { ColumnTitle = L["trade_name", "Trade Name"], ColumnName = nameof(Website.TradeName), HasSort = true, HasSearch = true },
                new() { ColumnTitle = L["brand", "Brand"], ColumnName = nameof(Website.BrandName), HasSort = true, HasSearch = true },
                new() { ColumnTitle = L["address", "Address"], ColumnName = nameof(Website.WebsiteAddress), HasSearch = true },
                new() { ColumnTitle = L["manager", "Manager"], ColumnName = nameof(Website.Manager), HasSearch = true },
                new() { ColumnTitle = L["type", "Type"], ColumnName = nameof(Website.WebsiteType), HasSort = true },
                new()
                {
                    ColumnTitle = L["status", "Status"],
                    ColumnName = nameof(Website.Active),
                    HasSearch = true,
                    SearchType = SearchColumnType.DropDown,
                    OtherDropDownValues = new() { [L["active", "Active"]] = "true", [L["inactive", "Inactive"]] = "false" }
                },
            }
        };

        await LoadAsync();
    }

    private Task OnGridChanged(GridViewHeaderParameters _) => LoadAsync();

    private async Task LoadAsync()
    {
        _loading = true;
        var result = await WebsiteService.GetPagedAsync(_grid.ToQuery());
        _websites = result.Items.ToList();
        _grid.Pagination.MaxLength = result.TotalCount;
        _loading = false;
    }
}
