@page "/websites"
@attribute [Authorize(Policy = AdminPolicies.SuperAdminOnly)]
@inject IWebsiteService WebsiteService

<PageTitle>Websites</PageTitle>
<h1>Websites</h1>

@if (_loading)
{
    <p>Loading...</p>
}
else
{
    <table>
        <thead>
            <tr><th>ID</th><th>Trade name</th><th>Address</th><th>Brand</th><th>Active</th></tr>
        </thead>
        <tbody>
            @foreach (var site in _websites)
            {
                <tr>
                    <td>@site.WebsiteID</td>
                    <td><a href="/websites/@site.WebsiteID">@site.TradeName</a></td>
                    <td>@site.WebsiteAddress</td>
                    <td>@site.BrandName</td>
                    <td>@(site.Active ? "Yes" : "No")</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private bool _loading = true;
    private IEnumerable<Website> _websites = [];

    protected override async Task OnInitializedAsync()
    {
        _websites = await WebsiteService.GetAllAsync();
        _loading = false;
    }
}
