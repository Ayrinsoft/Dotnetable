@page "/websites/new"
@page "/websites/{Id:int}"
@attribute [Authorize(Policy = AdminPolicies.SuperAdminOnly)]
@inject IWebsiteService WebsiteService
@inject IFileService FileService
@inject IDialogService DialogService
@inject NavigationManager Nav
@inject ISnackbar Snackbar

<PageTitle>@(_isNew ? "New Website" : "Edit Website") — Dotnetable</PageTitle>

@* ── Breadcrumbs ───────────────────────────────────────────────── *@
<MudBreadcrumbs Items="_breadcrumbs" Class="px-0 pb-2" />

@* ── Page header ──────────────────────────────────────────────── *@
<MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
    <MudStack Spacing="0">
        <MudText Typo="Typo.h5" Class="fw-bold">@(_isNew ? "New Website" : "Edit Website")</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">
            @(_isNew ? "Register a new website in the system" : $"Editing website #{Id}")
        </MudText>
    </MudStack>
</MudStack>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4" />
}
else if (_website is not null)
{
    <MudForm @ref="_form">
        <MudGrid Spacing="4">

            @* ── Basic info ──────────────────────────────────── *@
            <MudItem xs="12">
                <MudPaper Elevation="0" Class="border rounded-lg pa-6">
                    <MudText Typo="Typo.subtitle1" Class="fw-bold mb-4">
                        <MudIcon Icon="@Icons.Material.Filled.Info" Size="Size.Small" Class="me-1" />
                        Basic Information
                    </MudText>
                    <MudGrid Spacing="3">
                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="_website.TradeName" Label="Trade Name"
                                          Variant="Variant.Outlined" Required="true"
                                          RequiredError="Trade name is required." />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="_website.BrandName" Label="Brand Name"
                                          Variant="Variant.Outlined" Required="true"
                                          RequiredError="Brand name is required." />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="_website.WebsiteAddress" Label="Website Address"
                                          Variant="Variant.Outlined" Required="true"
                                          RequiredError="Website address is required."
                                          Placeholder="example.com" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="_website.DefaultLanguageCode" Label="Default Language Code"
                                          Variant="Variant.Outlined" MaxLength="2" Placeholder="en" />
                        </MudItem>
                        <MudItem xs="12" sm="6">
                            <MudSelect T="byte" @bind-Value="_website.WebsiteType" Label="Website Type"
                                       Variant="Variant.Outlined"
                                       HelperText="Stores get the e-commerce dashboard.">
                                <MudSelectItem T="byte" Value="@((byte)0)">Website</MudSelectItem>
                                <MudSelectItem T="byte" Value="@((byte)1)">Store</MudSelectItem>
                            </MudSelect>
                        </MudItem>
                    </MudGrid>
                </MudPaper>
            </MudItem>

            @* ── Contact info ─────────────────────────────── *@
            <MudItem xs="12">
                <MudPaper Elevation="0" Class="border rounded-lg pa-6">
                    <MudText Typo="Typo.subtitle1" Class="fw-bold mb-4">
                        <MudIcon Icon="@Icons.Material.Filled.ContactPhone" Size="Size.Small" Class="me-1" />
                        Contact Information
                    </MudText>
                    <MudGrid Spacing="3">
                        <MudItem xs="12" sm="4">
                            <MudTextField @bind-Value="_website.Manager" Label="Manager"
                                          Variant="Variant.Outlined" Required="true"
                                          RequiredError="Manager name is required." />
                        </MudItem>
                        <MudItem xs="12" sm="4">
                            <MudTextField @bind-Value="_website.Mobile" Label="Mobile"
                                          Variant="Variant.Outlined"
                                          Adornment="Adornment.Start"
                                          AdornmentIcon="@Icons.Material.Filled.Phone" />
                        </MudItem>
                        <MudItem xs="12" sm="4">
                            <MudTextField @bind-Value="_website.Email" Label="Email"
                                          Variant="Variant.Outlined" InputType="InputType.Email"
                                          Adornment="Adornment.Start"
                                          AdornmentIcon="@Icons.Material.Filled.Email" />
                        </MudItem>
                    </MudGrid>
                </MudPaper>
            </MudItem>

            @* ── Branding ─────────────────────────────────── *@
            <MudItem xs="12">
                <MudPaper Elevation="0" Class="border rounded-lg pa-6">
                    <MudText Typo="Typo.subtitle1" Class="fw-bold mb-4">
                        <MudIcon Icon="@Icons.Material.Filled.Image" Size="Size.Small" Class="me-1" />
                        Branding
                    </MudText>
                    @if (_isNew)
                    {
                        <MudAlert Severity="Severity.Info" Dense="true">
                            Save the website first, then pick a logo and favicon from its media library.
                        </MudAlert>
                    }
                    else
                    {
                        <MudGrid Spacing="3">
                            <MudItem xs="12" sm="6">
                                <MudText Typo="Typo.body2" Class="mb-1">Logo</MudText>
                                <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                    <div class="border rounded" style="width:64px; height:64px; display:flex; align-items:center; justify-content:center; overflow:hidden; background:var(--mud-palette-background-grey);">
                                        @if (_logoFile is { CNDUrl: not null })
                                        {
                                            <img src="@(_logoFile.ThumbnailCDN ?? _logoFile.CNDUrl)" style="width:100%; height:100%; object-fit:cover;" />
                                        }
                                        else
                                        {
                                            <MudIcon Icon="@Icons.Material.Filled.Image" Color="Color.Secondary" />
                                        }
                                    </div>
                                    <MudButton Variant="Variant.Outlined" Size="Size.Small" OnClick="PickLogoAsync">Choose</MudButton>
                                    @if (_website!.LogoFileID is not null)
                                    {
                                        <MudIconButton Icon="@Icons.Material.Filled.Clear" Size="Size.Small" OnClick="ClearLogo" />
                                    }
                                </MudStack>
                            </MudItem>
                            <MudItem xs="12" sm="6">
                                <MudText Typo="Typo.body2" Class="mb-1">Favicon</MudText>
                                <MudStack Row="true" Spacing="2" AlignItems="AlignItems.Center">
                                    <div class="border rounded" style="width:64px; height:64px; display:flex; align-items:center; justify-content:center; overflow:hidden; background:var(--mud-palette-background-grey);">
                                        @if (_faveFile is { CNDUrl: not null })
                                        {
                                            <img src="@(_faveFile.ThumbnailCDN ?? _faveFile.CNDUrl)" style="width:100%; height:100%; object-fit:cover;" />
                                        }
                                        else
                                        {
                                            <MudIcon Icon="@Icons.Material.Filled.Image" Color="Color.Secondary" />
                                        }
                                    </div>
                                    <MudButton Variant="Variant.Outlined" Size="Size.Small" OnClick="PickFaveAsync">Choose</MudButton>
                                    @if (_website!.FaveIconFileID is not null)
                                    {
                                        <MudIconButton Icon="@Icons.Material.Filled.Clear" Size="Size.Small" OnClick="ClearFave" />
                                    }
                                </MudStack>
                            </MudItem>
                        </MudGrid>
                    }
                </MudPaper>
            </MudItem>

            @* ── Status ───────────────────────────────────── *@
            <MudItem xs="12">
                <MudPaper Elevation="0" Class="border rounded-lg pa-6">
                    <MudText Typo="Typo.subtitle1" Class="fw-bold mb-4">
                        <MudIcon Icon="@Icons.Material.Filled.ToggleOn" Size="Size.Small" Class="me-1" />
                        Status
                    </MudText>
                    <MudSwitch T="bool" @bind-Value="_website.Active" Color="Color.Primary"
                               Label="@(_website.Active ? "Active — visible and accessible" : "Inactive — hidden from users")" />
                </MudPaper>
            </MudItem>

        </MudGrid>

        @* ── Action buttons ───────────────────────────────────────── *@
        <MudStack Row="true" Class="mt-4" Spacing="2">
            <MudButton Variant="Variant.Filled" Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Save"
                       OnClick="SaveAsync" Disabled="@_saving">
                @if (_saving)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="me-2" />
                }
                @(_isNew ? "Create Website" : "Save Changes")
            </MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Default"
                       StartIcon="@Icons.Material.Filled.ArrowBack"
                       Href="/websites">
                Cancel
            </MudButton>
        </MudStack>
    </MudForm>
}

@code {
    [Parameter] public int Id { get; set; }

    private MudForm _form = null!;
    private Website? _website;
    private FileRecord? _logoFile;
    private FileRecord? _faveFile;
    private bool _loading = true;
    private bool _saving;
    private bool _isNew => Id == 0;

    private List<BreadcrumbItem> _breadcrumbs => new()
    {
        new("Dashboard", "/"),
        new("Websites", "/websites"),
        new(_isNew ? "New" : $"#{Id}", null, true),
    };

    protected override async Task OnInitializedAsync()
    {
        if (_isNew)
        {
            _website = new Website
            {
                Active = true,
                DefaultLanguageCode = "en",
            };
        }
        else
        {
            _website = await WebsiteService.GetByIdAsync(Id);
            if (_website is null) Nav.NavigateTo("/websites");
            else
            {
                if (_website.LogoFileID is int logoId) _logoFile = await FileService.GetByIdAsync(logoId);
                if (_website.FaveIconFileID is int faveId) _faveFile = await FileService.GetByIdAsync(faveId);
            }
        }
        _loading = false;
    }

    private async Task PickLogoAsync()
    {
        var picked = await PickImageAsync();
        if (picked is not null) { _website!.LogoFileID = picked.FileRecordID; _logoFile = picked; }
    }

    private async Task PickFaveAsync()
    {
        var picked = await PickImageAsync();
        if (picked is not null) { _website!.FaveIconFileID = picked.FileRecordID; _faveFile = picked; }
    }

    private void ClearLogo() { _website!.LogoFileID = null; _logoFile = null; }
    private void ClearFave() { _website!.FaveIconFileID = null; _faveFile = null; }

    private async Task<FileRecord?> PickImageAsync()
    {
        var parameters = new DialogParameters
        {
            [nameof(FilePickerDialog.WebsiteId)] = Id,
            [nameof(FilePickerDialog.Category)] = FileCategory.Image,
        };
        var dialog = await DialogService.ShowAsync<FilePickerDialog>("Select a file", parameters,
            new DialogOptions { MaxWidth = MaxWidth.Medium, FullWidth = true });
        var result = await dialog.Result;
        return result is { Canceled: false, Data: FileRecord file } ? file : null;
    }

    private async Task SaveAsync()
    {
        await _form.ValidateAsync();
        if (!_form.IsValid) return;

        _saving = true;
        try
        {
            if (_isNew)
            {
                _website!.RegisterDate = DateOnly.FromDateTime(DateTime.UtcNow);
                _website.AuthCode = Guid.NewGuid();
                _website.AllowAllIP = true;
                await WebsiteService.CreateAsync(_website!);
                Snackbar.Add("Website created successfully.", Severity.Success);
            }
            else
            {
                await WebsiteService.UpdateAsync(_website!);
                Snackbar.Add("Changes saved successfully.", Severity.Success);
            }
            Nav.NavigateTo("/websites");
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Save failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _saving = false;
        }
    }
}
