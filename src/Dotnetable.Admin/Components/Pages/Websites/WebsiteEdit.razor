@page "/websites/{Id:int}"
@attribute [Authorize(Policy = AdminPolicies.SuperAdminOnly)]
@inject IWebsiteService WebsiteService
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthState

<PageTitle>Edit Website</PageTitle>
<h1>Edit Website</h1>

@if (_website is null)
{
    <p>Loading...</p>
}
else
{
    <div>
        <label>Name</label>
        <input @bind="_website.Name" />
    </div>
    <div>
        <label>Domain</label>
        <input @bind="_website.Domain" />
    </div>
    <div>
        <label>Active Theme</label>
        <input @bind="_website.ActiveTheme" />
    </div>
    <div>
        <label>Active</label>
        <input type="checkbox" @bind="_website.IsActive" />
    </div>
    <button @onclick="SaveAsync">Save</button>
    @if (!string.IsNullOrEmpty(_message))
    {
        <p>@_message</p>
    }
}

@code {
    [Parameter] public int Id { get; set; }

    private Website? _website;
    private string? _message;

    protected override async Task OnInitializedAsync()
    {
        _website = await WebsiteService.GetByIdAsync(Id);
        if (_website is null) Nav.NavigateTo("/websites");
    }

    private async Task SaveAsync()
    {
        if (_website is null) return;
        await WebsiteService.UpdateAsync(_website);
        _message = "Saved successfully.";
    }
}
