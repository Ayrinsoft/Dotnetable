@page "/websites/{Id:int}"
@attribute [Authorize(Policy = AdminPolicies.SuperAdminOnly)]
@inject IWebsiteService WebsiteService
@inject NavigationManager Nav

<PageTitle>Edit Website</PageTitle>
<h1>Edit Website</h1>

@if (_website is null)
{
    <p>Loading...</p>
}
else
{
    <div>
        <label>Trade name</label>
        <input @bind="_website.TradeName" />
    </div>
    <div>
        <label>Brand name</label>
        <input @bind="_website.BrandName" />
    </div>
    <div>
        <label>Website address</label>
        <input @bind="_website.WebsiteAddress" />
    </div>
    <div>
        <label>Manager</label>
        <input @bind="_website.Manager" />
    </div>
    <div>
        <label>Mobile</label>
        <input @bind="_website.Mobile" />
    </div>
    <div>
        <label>Email</label>
        <input @bind="_website.Email" />
    </div>
    <div>
        <label>Active</label>
        <input type="checkbox" @bind="_website.Active" />
    </div>
    <button @onclick="SaveAsync">Save</button>
    @if (!string.IsNullOrEmpty(_message))
    {
        <p>@_message</p>
    }
}

@code {
    [Parameter] public int Id { get; set; }

    private Website? _website;
    private string? _message;

    protected override async Task OnInitializedAsync()
    {
        _website = await WebsiteService.GetByIdAsync(Id);
        if (_website is null) Nav.NavigateTo("/websites");
    }

    private async Task SaveAsync()
    {
        if (_website is null) return;
        await WebsiteService.UpdateAsync(_website);
        _message = "Saved successfully.";
    }
}
