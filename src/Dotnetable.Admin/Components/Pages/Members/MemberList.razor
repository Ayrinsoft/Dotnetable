@page "/members"
@attribute [Authorize(Policy = AdminPolicies.WebsiteAdminOrAbove)]
@inject IMemberService MemberService
@inject AuthenticationStateProvider AuthState

<PageTitle>Members — Dotnetable</PageTitle>

@* ── Page header ──────────────────────────────────────────────── *@
<MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
    <MudStack Spacing="0">
        <MudText Typo="Typo.h5" Class="fw-bold">Members</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">
            @(_isMaster ? "All members across all websites" : "Members of your website")
        </MudText>
    </MudStack>
    <MudButton Variant="Variant.Filled" Color="Color.Primary"
               StartIcon="@Icons.Material.Filled.Add"
               Href="/members/new">
        New Member
    </MudButton>
</MudStack>

<MudPaper Elevation="0" Class="app-card rounded-lg pa-4">
    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-3" />
    }
    <DNGridView GridHeaderParams="_grid" OnSearchChanged="OnGridChanged">
        @if (_members.Count == 0)
        {
            <tr>
                <td colspan="@_colCount" style="text-align:center; padding:32px;">
                    <MudText Color="Color.Secondary">No members found.</MudText>
                </td>
            </tr>
        }
        else
        {
            @foreach (var m in _members)
            {
                <tr>
                    <td>
                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                       Color="Color.Primary" Href="@($"/members/{m.MemberID}")" />
                    </td>
                    <td>@m.MemberID</td>
                    <td>@m.Username</td>
                    <td>@m.Email</td>
                    <td>
                        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                            <MudAvatar Color="Color.Primary" Size="Size.Small">
                                @(string.IsNullOrWhiteSpace(m.Givenname) ? "?" : m.Givenname.Trim()[..1].ToUpper())
                            </MudAvatar>
                            <span>@m.Givenname @m.Surname</span>
                        </MudStack>
                    </td>
                    @if (_isMaster)
                    {
                        <td>@m.WebsiteID</td>
                    }
                    <td>@m.RegisterDate.ToString("yyyy-MM-dd")</td>
                    <td>
                        <MudSwitch T="bool" Value="m.Active" Color="Color.Success"
                                   Disabled="_toggling.Contains(m.MemberID)"
                                   ValueChanged="@(v => ToggleActiveAsync(m, v))" />
                    </td>
                </tr>
            }
        }
    </DNGridView>
</MudPaper>

@code {
    private bool _loading = true;
    private bool _isMaster;
    private int _websiteId;
    private List<Member> _members = new();
    private HashSet<int> _toggling = new();
    private GridViewHeaderParameters _grid = new();

    private int _colCount => 7 + (_isMaster ? 1 : 0);

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthState.GetAuthenticationStateAsync();
        var user = state.User;
        _isMaster = user.HasClaim(AdminClaimTypes.Master, "true");
        int.TryParse(user.FindFirst(AdminClaimTypes.WebsiteId)?.Value, out _websiteId);

        _grid = new GridViewHeaderParameters
        {
            Pagination = new PaginationModel { PageSize = 25 },
            HeaderItems = new()
            {
                new() { ColumnTitle = "", ColumnName = "" },
                new() { ColumnTitle = "ID", ColumnName = nameof(Member.MemberID), HasSort = true },
                new() { ColumnTitle = "Username", ColumnName = nameof(Member.Username), HasSort = true, HasSearch = true },
                new() { ColumnTitle = "Email", ColumnName = nameof(Member.Email), HasSort = true, HasSearch = true },
                new() { ColumnTitle = "Full Name", ColumnName = "Fullname", HasSearch = true },
            }
        };
        if (_isMaster)
            _grid.HeaderItems.Add(new() { ColumnTitle = "Website", ColumnName = nameof(Member.WebsiteID), HasSort = true });
        _grid.HeaderItems.Add(new() { ColumnTitle = "Registered", ColumnName = nameof(Member.RegisterDate), HasSort = true });
        _grid.HeaderItems.Add(new()
        {
            ColumnTitle = "Status",
            ColumnName = nameof(Member.Active),
            HasSearch = true,
            SearchType = SearchColumnType.DropDown,
            OtherDropDownValues = new() { ["Active"] = "true", ["Inactive"] = "false" }
        });

        await LoadAsync();
    }

    private Task OnGridChanged(GridViewHeaderParameters _) => LoadAsync();

    private async Task ToggleActiveAsync(Member m, bool value)
    {
        if (!_toggling.Add(m.MemberID)) return;
        m.Active = value;
        try { await MemberService.SetActiveAsync(m.MemberID, value); }
        finally { _toggling.Remove(m.MemberID); }
    }

    private async Task LoadAsync()
    {
        _loading = true;
        var result = await MemberService.GetPagedAsync(_isMaster ? null : _websiteId, _grid.ToQuery());
        _members = result.Items.ToList();
        _grid.Pagination.MaxLength = result.TotalCount;
        _loading = false;
    }
}
