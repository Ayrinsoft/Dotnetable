@page "/members"
@attribute [Authorize(Policy = AdminPolicies.WebsiteAdminOrAbove)]
@inject IMemberService MemberService
@inject AuthenticationStateProvider AuthState

<PageTitle>Members — Dotnetable</PageTitle>

@* ── Page header ──────────────────────────────────────────────── *@
<MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-4">
    <MudStack Spacing="0">
        <MudText Typo="Typo.h5" Class="fw-bold">Members</MudText>
        <MudText Typo="Typo.body2" Color="Color.Secondary">
            @(_isMaster ? "All members across all websites" : "Members of your website")
        </MudText>
    </MudStack>
</MudStack>

@* ── Data grid ────────────────────────────────────────────────── *@
<MudPaper Elevation="0" Class="border rounded-lg overflow-hidden">
    <MudDataGrid T="Member" Items="@_members" QuickFilter="@_quickFilter"
                 Loading="@_loading" Hover="true" Dense="false" Elevation="0"
                 SortMode="SortMode.Multiple" Filterable="false">
        <ToolBarContent>
            <MudSpacer />
            <MudTextField @bind-Value="_search" Placeholder="Search…"
                          Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search"
                          IconSize="Size.Medium" Class="mt-0 mb-0" Variant="Variant.Outlined"
                          Margin="Margin.Dense" Immediate="true" />
        </ToolBarContent>
        <Columns>
            <PropertyColumn Property="x => x.MemberID" Title="ID" Sortable="true" InitialDirection="SortDirection.Ascending" />
            <PropertyColumn Property="x => x.Username" Title="Username" Sortable="true" />
            <PropertyColumn Property="x => x.Email" Title="Email" Sortable="true" />
            <TemplateColumn Title="Full Name" Sortable="false">
                <CellTemplate>
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
                        <MudAvatar Color="Color.Primary" Size="Size.Small">
                            @(context.Item.Givenname?.Trim()[0].ToString().ToUpper() ?? "?")
                        </MudAvatar>
                        <MudText>@context.Item.Givenname @context.Item.Surname</MudText>
                    </MudStack>
                </CellTemplate>
            </TemplateColumn>
            @if (_isMaster)
            {
                <PropertyColumn Property="x => x.WebsiteID" Title="Website" Sortable="true" />
            }
            <PropertyColumn Property="x => x.RegisterDate" Title="Registered" Sortable="true" />
            <TemplateColumn Title="Status" Sortable="false">
                <CellTemplate>
                    @if (context.Item.Active)
                    {
                        <MudChip T="string" Color="Color.Success" Size="Size.Small" Variant="Variant.Filled">Active</MudChip>
                    }
                    else
                    {
                        <MudChip T="string" Color="Color.Default" Size="Size.Small" Variant="Variant.Outlined">Inactive</MudChip>
                    }
                </CellTemplate>
            </TemplateColumn>
        </Columns>
        <NoRecordsContent>
            <MudStack AlignItems="AlignItems.Center" Class="pa-8" Spacing="2">
                <MudIcon Icon="@Icons.Material.Filled.People" Size="Size.Large" Color="Color.Secondary" />
                <MudText Color="Color.Secondary">No members found.</MudText>
            </MudStack>
        </NoRecordsContent>
        <LoadingContent>
            <MudStack AlignItems="AlignItems.Center" Class="pa-8">
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
            </MudStack>
        </LoadingContent>
    </MudDataGrid>
</MudPaper>

@code {
    private bool _loading = true;
    private bool _isMaster;
    private string _search = string.Empty;
    private IEnumerable<Member> _members = [];

    private Func<Member, bool> _quickFilter => x =>
        string.IsNullOrWhiteSpace(_search)
        || x.Username.Contains(_search, StringComparison.OrdinalIgnoreCase)
        || x.Email.Contains(_search, StringComparison.OrdinalIgnoreCase)
        || ($"{x.Givenname} {x.Surname}").Contains(_search, StringComparison.OrdinalIgnoreCase);

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthState.GetAuthenticationStateAsync();
        var user = state.User;
        _isMaster = user.HasClaim(AdminClaimTypes.Master, "true");

        if (_isMaster)
        {
            _members = await MemberService.GetAllAsync();
        }
        else
        {
            int.TryParse(user.FindFirst(AdminClaimTypes.WebsiteId)?.Value, out var websiteId);
            _members = await MemberService.GetByWebsiteAsync(websiteId);
        }
        _loading = false;
    }
}
