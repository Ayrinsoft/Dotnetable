@page "/posts"
@attribute [Authorize(Policy = AdminPolicies.WebsiteAdminOrAbove)]
@inject IPostService PostService
@inject AuthenticationStateProvider AuthState

<PageTitle>Posts</PageTitle>
<h1>Posts</h1>

@if (_loading)
{
    <p>Loading...</p>
}
else
{
    <table>
        <thead>
            <tr><th>ID</th><th>Title</th><th>Type</th><th>Status</th><th>Published</th></tr>
        </thead>
        <tbody>
            @foreach (var post in _posts)
            {
                <tr>
                    <td>@post.Id</td>
                    <td>@post.Title</td>
                    <td>@post.Type</td>
                    <td>@post.Status</td>
                    <td>@post.PublishedAt?.ToString("yyyy-MM-dd")</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private bool _loading = true;
    private IEnumerable<Post> _posts = [];

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthState.GetAuthenticationStateAsync();
        var user = state.User;

        int websiteId = int.Parse(
            user.FindFirst(AdminClaimTypes.WebsiteId)?.Value
            ?? user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)!.Value);

        _posts = await PostService.GetByWebsiteAsync(websiteId);
        _loading = false;
    }
}
