<MudNavMenu Class="pt-1">

    <span class="app-nav-label">Navigation</span>
    <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard">
        Dashboard
    </MudNavLink>

    <AuthorizeView Policy="@AdminPolicies.WebsiteAdminOrAbove">
        <span class="app-nav-label">Management</span>
        <MudNavGroup Title="User Management" Icon="@Icons.Material.Filled.People" Expanded="true">
            <MudNavLink Href="/members" Icon="@Icons.Material.Filled.PersonOutline">
                Members
            </MudNavLink>
            <MudNavLink Href="/policies" Icon="@Icons.Material.Filled.Shield">
                Access Levels
            </MudNavLink>
            <AuthorizeView Policy="@AdminPolicies.SuperAdminOnly" Context="roles">
                <MudNavLink Href="/roles" Icon="@Icons.Material.Filled.VpnKey">
                    Roles
                </MudNavLink>
            </AuthorizeView>
            <MudNavLink Href="/login-logs" Icon="@Icons.Material.Filled.History">
                Login Logs
            </MudNavLink>
        </MudNavGroup>
        <MudNavLink Href="/translations" Icon="@Icons.Material.Filled.Translate">
            Translations
        </MudNavLink>
    </AuthorizeView>

    <AuthorizeView Policy="@AdminPolicies.SuperAdminOnly">
        <span class="app-nav-label">Administration</span>
        <MudNavLink Href="/websites" Icon="@Icons.Material.Filled.Language">
            Websites
        </MudNavLink>

        <span class="app-nav-label">System</span>
        <MudNavLink Href="/system/updates" Icon="@Icons.Material.Filled.SystemUpdateAlt">
            DB Updates
        </MudNavLink>
        <MudNavLink Href="/settings" Icon="@Icons.Material.Filled.Settings">
            Settings
        </MudNavLink>
    </AuthorizeView>

</MudNavMenu>
