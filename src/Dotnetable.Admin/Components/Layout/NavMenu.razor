@inject IPageLocalizer L

<MudNavMenu Class="pt-1">

    <span class="app-nav-label">@L["nav.navigation", "Navigation"]</span>
    <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard">
        @L["dashboard", "Dashboard"]
    </MudNavLink>

    @if (_canMembers || _canPolicies || _canLoginLogs || _canMessages || _canWebsite || _isMaster)
    {
        <span class="app-nav-label">@L["nav.management", "Management"]</span>
    }
    <MudNavGroup Title="@L["nav.user_management", "User Management"]" Icon="@Icons.Material.Filled.People" Expanded="true"
                 Hidden="@(!_canMembers && !_canPolicies && !_canLoginLogs && !_isMaster)">
        <AuthorizeView Policy="@RoleKeys.MembersView" Context="m">
            <MudNavLink Href="/members" Icon="@Icons.Material.Filled.PersonOutline">
                @L["members", "Members"]
            </MudNavLink>
        </AuthorizeView>
        <AuthorizeView Policy="@RoleKeys.PoliciesView" Context="p">
            <MudNavLink Href="/policies" Icon="@Icons.Material.Filled.Shield">
                @L["access_levels", "Access Levels"]
            </MudNavLink>
        </AuthorizeView>
        <AuthorizeView Policy="@AdminPolicies.SuperAdminOnly" Context="roles">
            <MudNavLink Href="/roles" Icon="@Icons.Material.Filled.VpnKey">
                @L["roles", "Roles"]
            </MudNavLink>
        </AuthorizeView>
        <AuthorizeView Policy="@RoleKeys.LoginLogsView" Context="ll">
            <MudNavLink Href="/login-logs" Icon="@Icons.Material.Filled.History">
                @L["login_logs", "Login Logs"]
            </MudNavLink>
        </AuthorizeView>
    </MudNavGroup>

    <AuthorizeView Policy="@RoleKeys.WebsiteEdit" Context="ws">
        <MudNavGroup Title="@L["website", "Website"]" Icon="@Icons.Material.Filled.WebAsset">
            <MudNavLink Href="/website/ips" Icon="@Icons.Material.Filled.Security">
                @L["ip_whitelist", "IP Whitelist"]
            </MudNavLink>
            <MudNavLink Href="/website/scripts" Icon="@Icons.Material.Filled.Code">
                @L["scripts", "Scripts"]
            </MudNavLink>
            <MudNavLink Href="/website/seo" Icon="@Icons.Material.Filled.Search">
                @L["seo_settings", "SEO Settings"]
            </MudNavLink>
            <MudNavLink Href="/website/social" Icon="@Icons.Material.Filled.Share">
                @L["social_links", "Social Links"]
            </MudNavLink>
        </MudNavGroup>
    </AuthorizeView>

    <MudNavGroup Title="@L["messages", "Messages"]" Icon="@Icons.Material.Filled.Message"
                 Hidden="@(!_canMessages && !_canWebsite && !_isMaster)">
        <AuthorizeView Policy="@RoleKeys.MessagesView" Context="cm">
            <MudNavLink Href="/messages/contacts" Icon="@Icons.Material.Filled.ContactMail">
                @L["contact_messages", "Contact Messages"]
            </MudNavLink>
        </AuthorizeView>
        <AuthorizeView Policy="@RoleKeys.WebsiteEdit" Context="em">
            <MudNavLink Href="/messages/email" Icon="@Icons.Material.Filled.Email">
                @L["email_settings", "Email Settings"]
            </MudNavLink>
        </AuthorizeView>
    </MudNavGroup>

    <AuthorizeView Policy="@RoleKeys.LocalizationEdit" Context="tr">
        <MudNavLink Href="/translations" Icon="@Icons.Material.Filled.Translate">
            @L["translations", "Translations"]
        </MudNavLink>
    </AuthorizeView>
    <AuthorizeView Policy="@RoleKeys.MediaView" Context="md">
        <MudNavGroup Title="@L["media", "Media"]" Icon="@Icons.Material.Filled.PermMedia">
            <MudNavLink Href="/media" Icon="@Icons.Material.Filled.PhotoLibrary">
                @L["media_library", "Media Library"]
            </MudNavLink>
            <AuthorizeView Policy="@RoleKeys.MediaUpload" Context="ms">
                <MudNavLink Href="/media/storage" Icon="@Icons.Material.Filled.Cloud">
                    @L["storage", "Storage"]
                </MudNavLink>
            </AuthorizeView>
        </MudNavGroup>
    </AuthorizeView>

    <AuthorizeView Policy="@AdminPolicies.SuperAdminOnly">
        <span class="app-nav-label">@L["nav.administration", "Administration"]</span>
        <MudNavLink Href="/websites" Icon="@Icons.Material.Filled.Language">
            @L["websites", "Websites"]
        </MudNavLink>

        <MudNavGroup Title="@L["initial_data", "Initial Data"]" Icon="@Icons.Material.Filled.Storage">
            <MudNavLink Href="/initial-data/countries" Icon="@Icons.Material.Filled.Flag">
                @L["countries", "Countries"]
            </MudNavLink>
            <MudNavLink Href="/initial-data/states" Icon="@Icons.Material.Filled.Map">
                @L["states", "States / Provinces"]
            </MudNavLink>
            <MudNavLink Href="/initial-data/cities" Icon="@Icons.Material.Filled.LocationCity">
                @L["cities", "Cities"]
            </MudNavLink>
        </MudNavGroup>

        <span class="app-nav-label">@L["nav.system", "System"]</span>
        <MudNavLink Href="/system/updates" Icon="@Icons.Material.Filled.SystemUpdateAlt">
            @L["db_updates", "DB Updates"]
        </MudNavLink>
        <MudNavLink Href="/settings" Icon="@Icons.Material.Filled.Settings">
            @L["settings", "Settings"]
        </MudNavLink>
    </AuthorizeView>

</MudNavMenu>

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private bool _isMaster;
    private bool _canMembers;
    private bool _canPolicies;
    private bool _canLoginLogs;
    private bool _canMessages;
    private bool _canWebsite;

    protected override async Task OnInitializedAsync()
    {
        await L.EnsureLoadedAsync();

        if (AuthState is not null)
        {
            var user = (await AuthState).User;
            _isMaster = user.HasClaim(AdminClaimTypes.Master, "true");
            _canMembers = AdminPolicies.Allows(user, RoleKeys.MembersView);
            _canPolicies = AdminPolicies.Allows(user, RoleKeys.PoliciesView);
            _canLoginLogs = AdminPolicies.Allows(user, RoleKeys.LoginLogsView);
            _canMessages = AdminPolicies.Allows(user, RoleKeys.MessagesView);
            _canWebsite = AdminPolicies.Allows(user, RoleKeys.WebsiteEdit);
        }
    }
}
