@page
@model Dotnetable.Admin.Pages.ForgotPasswordModel
@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Forgot password";
}

<p class="auth-subtitle">Enter your username or email and we'll send you a reset link.</p>

@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{
    <div class="alert alert-success">@Model.SuccessMessage</div>
    <div class="auth-links"><a asp-page="/Login">Back to sign in</a></div>
}
else
{
    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-error">@Model.ErrorMessage</div>
    }

    <form method="post">
        <div class="field">
            <label asp-for="EmailOrUsername">Username or email</label>
            <input asp-for="EmailOrUsername" type="text" autocomplete="username" autofocus />
            <span asp-validation-for="EmailOrUsername" class="field-error"></span>
        </div>

        <partial name="_Captcha" model="Model" />

        <button type="submit" class="btn">Send reset link</button>

        <div class="auth-links">
            <a asp-page="/Login">Back to sign in</a>
        </div>
    </form>
}
