@page
@model Dotnetable.Admin.Pages.ResetPasswordModel
@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Reset password";
}

@if (Model.Completed)
{
    <p class="auth-subtitle">Your password has been updated.</p>
    <div class="alert alert-success">You can now sign in with your new password.</div>
    <div class="auth-links"><a asp-page="/Login">Go to sign in</a></div>
}
else if (!Model.KeyValid)
{
    <p class="auth-subtitle">Reset link problem.</p>
    <div class="alert alert-error">This password reset link is invalid or has expired.</div>
    <div class="auth-links"><a asp-page="/ForgotPassword">Request a new link</a></div>
}
else
{
    <p class="auth-subtitle">Choose a new password for your account.</p>

    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="alert alert-error">@Model.ErrorMessage</div>
    }

    <form method="post">
        <input type="hidden" asp-for="Key" />

        <div class="field">
            <label asp-for="Password">New password</label>
            <input asp-for="Password" type="password" autocomplete="new-password" autofocus />
            <span asp-validation-for="Password" class="field-error"></span>
        </div>

        <div class="field">
            <label asp-for="ConfirmPassword">Confirm password</label>
            <input asp-for="ConfirmPassword" type="password" autocomplete="new-password" />
            <span asp-validation-for="ConfirmPassword" class="field-error"></span>
        </div>

        <partial name="_Captcha" model="Model" />

        <button type="submit" class="btn">Update password</button>

        <div class="auth-links">
            <a asp-page="/Login">Back to sign in</a>
        </div>
    </form>
}
