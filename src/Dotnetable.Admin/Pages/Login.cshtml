@page
@model Dotnetable.Admin.Pages.LoginModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - Dotnetable Admin</title>
</head>
<body>
    <div style="max-width:400px;margin:80px auto;font-family:sans-serif">
        <h2>Dotnetable Admin</h2>
        <form method="post">
            <div asp-validation-summary="ModelOnly" style="color:red"></div>
            <div>
                <label>Username</label>
                <input asp-for="Input.Username" type="text" autocomplete="username" style="display:block;width:100%;padding:8px;margin:4px 0 12px" />
            </div>
            <div>
                <label>Password</label>
                <input asp-for="Input.Password" type="password" autocomplete="current-password" style="display:block;width:100%;padding:8px;margin:4px 0 12px" />
            </div>
            <button type="submit" style="padding:8px 20px">Login</button>
        </form>
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <p style="color:red;margin-top:12px">@Model.ErrorMessage</p>
        }
    </div>
</body>
</html>
