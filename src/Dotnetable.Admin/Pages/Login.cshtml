@page
@model Dotnetable.Admin.Pages.LoginModel
@{
    Layout = "_AuthLayout";
    ViewData["Title"] = "Login";
}

<p class="auth-subtitle">Let's get you signed in. Enter your credentials to continue.</p>

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-error">@Model.ErrorMessage</div>
}

<form method="post">
    <div class="field">
        <label asp-for="Input.Username">Username</label>
        <input asp-for="Input.Username" type="text" autocomplete="username" autofocus />
        <span asp-validation-for="Input.Username" class="field-error"></span>
    </div>

    <div class="field">
        <label asp-for="Input.Password">Password</label>
        <input asp-for="Input.Password" type="password" autocomplete="current-password" />
        <span asp-validation-for="Input.Password" class="field-error"></span>
    </div>

    <partial name="_Captcha" model="Model" />

    <button type="submit" class="btn">Sign in</button>

    <div class="auth-links">
        <a asp-page="/ForgotPassword">Forgot password?</a>
    </div>
</form>
