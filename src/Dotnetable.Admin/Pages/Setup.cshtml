@page
@model Dotnetable.Admin.Pages.SetupModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Initial Setup - Dotnetable Admin</title>
    <style>
        body { font-family: sans-serif; background: #f4f5f7; }
        .setup { max-width: 560px; margin: 48px auto; background: #fff; padding: 32px; border-radius: 8px; box-shadow: 0 1px 4px rgba(0,0,0,.1); }
        h2 { margin-top: 0; }
        h3 { margin: 24px 0 8px; border-bottom: 1px solid #eee; padding-bottom: 4px; }
        label { display: block; margin-top: 10px; font-size: 13px; color: #444; }
        input { display: block; width: 100%; padding: 8px; margin-top: 2px; box-sizing: border-box; }
        button { margin-top: 20px; padding: 10px 24px; background: #2563eb; color: #fff; border: 0; border-radius: 4px; cursor: pointer; }
        .err { color: #b91c1c; }
        .hint { color: #6b7280; font-size: 12px; }
    </style>
</head>
<body>
    <div class="setup">
        <h2>Welcome to Dotnetable</h2>
        <p class="hint">This is the first run. Enter your master website and administrator account to get started.
            The first website (ID 1) always has access to every other website.</p>

        <div asp-validation-summary="ModelOnly" class="err"></div>
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <p class="err">@Model.ErrorMessage</p>
        }
        @if (!string.IsNullOrEmpty(Model.TestMessage))
        {
            <p style="color:@(Model.TestSucceeded ? "#15803d" : "#b91c1c")">@Model.TestMessage</p>
        }

        <form method="post">
            <h3>Database</h3>
            <label>Provider</label>
            <select asp-for="Input.DbProvider">
                @foreach (var p in Dotnetable.Admin.Pages.SetupModel.Providers)
                {
                    <option value="@p.Value">@p.Label</option>
                }
            </select>
            <label>Server / host</label>
            <input asp-for="Input.DbServer" />
            <p class="hint">SQL Server: <code>.</code> or <code>.\SQLEXPRESS</code> or <code>localhost,1433</code>. Others: host name.</p>
            <label>Port (PostgreSQL / MySQL / MariaDB)</label>
            <input asp-for="Input.DbPort" type="number" />
            <label>Database name</label>
            <input asp-for="Input.DbName" />
            <label style="display:flex;align-items:center;gap:6px;margin-top:10px">
                <input asp-for="Input.DbIntegratedSecurity" type="checkbox" style="width:auto" />
                SQL Server: use Windows authentication (leave user/password blank)
            </label>
            <label>User</label>
            <input asp-for="Input.DbUser" autocomplete="off" />
            <label>Password</label>
            <input asp-for="Input.DbPassword" type="password" autocomplete="off" />
            <label style="display:flex;align-items:center;gap:6px;margin-top:10px">
                <input asp-for="Input.DbTrustServerCertificate" type="checkbox" style="width:auto" />
                SQL Server: trust server certificate
            </label>
            <label style="display:flex;align-items:center;gap:6px;margin-top:10px">
                <input asp-for="Input.CreateDatabaseIfMissing" type="checkbox" style="width:auto" />
                Create the database if it doesn't exist
            </label>
            <button type="submit" asp-page-handler="Test" style="background:#6b7280;margin-top:12px">Test connection</button>

            <h3>Website</h3>
            <label>Trade name</label>
            <input asp-for="Input.TradeName" />
            <label>Brand name (shown in page titles)</label>
            <input asp-for="Input.BrandName" />
            <label>Website address (domain)</label>
            <input asp-for="Input.WebsiteAddress" placeholder="example.com" />
            <label>Manager</label>
            <input asp-for="Input.Manager" />
            <label>Mobile</label>
            <input asp-for="Input.Mobile" />
            <label>Website email</label>
            <input asp-for="Input.WebsiteEmail" type="email" />
            <label>Default language code (2 letters)</label>
            <input asp-for="Input.DefaultLanguageCode" maxlength="2" />

            <h3>Administrator account</h3>
            <label>Username</label>
            <input asp-for="Input.Username" autocomplete="username" />
            <label>Password</label>
            <input asp-for="Input.Password" type="password" autocomplete="new-password" />
            <label>Email</label>
            <input asp-for="Input.Email" type="email" />
            <label>First name</label>
            <input asp-for="Input.Givenname" />
            <label>Last name</label>
            <input asp-for="Input.Surname" />

            <button type="submit">Create &amp; Continue</button>
        </form>
    </div>
</body>
</html>
